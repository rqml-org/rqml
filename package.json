{
  "name": "rqml-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "RQML reference toolchain: the @rqml/schema source of truth, the @rqml/core engine, the rqml CLI, the @rqml/mcp server, and the documentation site.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
