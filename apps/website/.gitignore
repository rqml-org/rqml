# are not tracked (avoids stale duplicates — REQ-SCHEMA-CANONICAL).
/static/AGENTS.md
/static/schema/

# Misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
