<?xml version="1.0" encoding="UTF-8"?>
<!--
  requirements.rqml — RQML specified in RQML.

  This document is the canonical self-description of the Requirements Markup
  Language (RQML) 2.2.0, written in RQML itself. It reverse-engineers the
  language's intent, structure, controlled vocabularies, traceability model,
  and lifecycle from the published XSD schema, the rqml.org documentation
  (why-rqml, why-xml, about), the changelog, and RFC-0002.

  The "system" being specified here is the RQML language and format — not an
  application. Domain entities therefore model the RQML metamodel (the shape
  of an RQML document), and requirements are normative statements about what a
  conforming RQML document and toolchain MUST do.
-->
<rqml xmlns="https://rqml.org/schema/2.2.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://rqml.org/schema/2.2.0 https://rqml.org/schema/rqml-2.2.0.xsd"
      version="2.2.0" docId="RQML-SELF-001" status="review">

  <!-- ============================================================= -->
  <!-- META                                                          -->
  <!-- ============================================================= -->
  <meta>
    <title>RQML — The Requirements Markup Language (Self-Specification)</title>
    <system>RQML</system>
    <summary>
      An LLM-first, human-readable XML standard for capturing software
      requirements as the primary, traceable, machine-checkable artifact of a
      project. This RQML document specifies RQML itself: its document model,
      controlled vocabularies, traceability graph, behavior model, and the
      spec-first development process it enables. It is the ultimate dogfood —
      RQML described in RQML. As of 2026-06 this document also specifies the
      RQML reference toolchain — the TypeScript monorepo housing the @rqml/core
      engine, the rqml CLI, and the @rqml/mcp server — and the deterministic,
      spec-first control loop those tools enable.
    </summary>
    <authors>
      <author>
        <name>Garðar Guðgeirsson</name>
        <role>RQML Maintainer</role>
        <org>rqml.org</org>
        <contact>https://github.com/gudgeirsson</contact>
      </author>
    </authors>
    <dates>
      <created>2026-02-01</created>
      <updated>2026-06-13</updated>
      <targetRelease>RQML 2.2.0</targetRelease>
    </dates>
    <conventions>
      <normativeKeywords>
        The key words MUST, MUST NOT, SHALL, SHALL NOT, SHOULD, SHOULD NOT,
        and MAY in this document are to be interpreted as described in RFC 2119
        / RFC 8174, mapped to the RQML PriorityType vocabulary (must / should / may).
      </normativeKeywords>
      <idConventions>
        IDs follow the RQML recommended patterns: REQ-&lt;AREA&gt;-NNN for
        requirements, GOAL-&lt;NAME&gt; for goals, QGOAL-&lt;NAME&gt; for quality
        goals, ENT-&lt;NAME&gt; for entities, SM-&lt;NAME&gt; / ST-&lt;NAME&gt; /
        TR-&lt;NAME&gt; for behavior, TC-&lt;NAME&gt; for tests, DEC-&lt;NAME&gt;
        for decisions, and RISK-&lt;NAME&gt; for risks.
      </idConventions>
    </conventions>
    <profiles>
      <profile id="PROF-LLM-NATIVE" type="llm-guidance">
        <description>
          Viewpoint optimizing the specification for consumption by LLM coding
          agents: explicit tag semantics, normative statements, and dense
          traceability so generation is "code from a specification," not
          "code from a prompt."
        </description>
      </profile>
    </profiles>
  </meta>

  <!-- ============================================================= -->
  <!-- CATALOGS                                                      -->
  <!-- ============================================================= -->
  <catalogs>
    <glossary>
      <term id="TERM-REQUIREMENT">
        <name>Requirement</name>
        <definition>
          A single, atomic, normative statement of what the system must do or
          how well it must do it, classified by type and expressed with RFC 2119
          keywords.
        </definition>
      </term>
      <term id="TERM-TRACE">
        <name>Traceability</name>
        <definition>
          The directed graph of typed relationships (edges) between RQML
          artifacts, enabling impact analysis ("what breaks if this changes?")
          and coverage analysis ("is this goal satisfied?").
        </definition>
      </term>
      <term id="TERM-GOAL">
        <name>Goal</name>
        <definition>
          An intentional statement of why the system exists — a desired state of
          the world — as opposed to an operational statement of how to achieve it.
        </definition>
      </term>
      <term id="TERM-SCENARIO">
        <name>Scenario</name>
        <definition>
          A narrative description of system usage. Positive use cases, negative
          misuse cases, and boundary edge cases each drive distinct requirement types.
        </definition>
      </term>
      <term id="TERM-ENTITY">
        <name>Entity</name>
        <definition>
          A core concept in the problem domain with attributes, forming part of
          the ubiquitous language and the basis for generated data models.
        </definition>
      </term>
      <term id="TERM-SM">
        <name>State Machine</name>
        <definition>
          A flat finite state machine formalizing an entity or process lifecycle
          as states and transitions with optional guards and actions.
        </definition>
      </term>
      <term id="TERM-LOCATOR">
        <name>Locator</name>
        <definition>
          A trace endpoint reference of one of three kinds: local (same
          document, keyref-validated), doc (another RQML document, optionally
          version/git-pinned), or external (any URI).
        </definition>
      </term>
      <term id="TERM-MIXED">
        <name>Mixed Content</name>
        <definition>
          Natural-language prose interrupted by structured elements within a
          single text block — the core reason RQML is a document format, not a
          data format.
        </definition>
        <synonyms>
          <synonym>rich text content</synonym>
        </synonyms>
      </term>
      <term id="TERM-GHOST">
        <name>Ghost feature</name>
        <definition>
          Implemented behavior in code that has no corresponding approved
          requirement in the spec. Tolerance for ghost features varies by
          strictness level.
        </definition>
      </term>
      <term id="TERM-NORMATIVE">
        <name>Normative keyword</name>
        <definition>
          An RFC 2119 modal verb (MUST/SHALL, SHOULD, MAY) that establishes the
          obligation level of a requirement statement.
        </definition>
      </term>
    </glossary>

    <actors>
      <actor id="ACT-LLM" name="LLM Coding Agent" type="system">
        <description>
          An AI assistant that both authors RQML (elicitation, normalization,
          ambiguity detection) and consumes it (code, test, and architecture
          generation). The primary intended reader of an RQML document.
        </description>
      </actor>
      <actor id="ACT-AUTHOR" name="Requirements Author" type="human">
        <description>
          A human engineer, product owner, or analyst who captures intent,
          reviews LLM-drafted requirements, and owns the specification.
        </description>
      </actor>
      <actor id="ACT-VALIDATOR" name="Schema Validator" type="system">
        <description>
          Tooling that validates an RQML document against the XSD: ID
          uniqueness, trace referential integrity, and state-machine well-formedness.
        </description>
      </actor>
      <actor id="ACT-TOOLING" name="RQML Tooling" type="system">
        <description>
          The RQML VS Code extension, the agent skill, CI checks, and
          generators that read and write RQML documents.
        </description>
      </actor>
      <actor id="ACT-CONTROL-LOOP" name="Enforcement Control Loop" type="system">
        <description>
          The deterministic harness — editor save hooks, agent session hooks, and
          CI jobs — that invokes the rqml toolchain to keep an agent working from
          the spec without relying on the model remembering to. The agent-specific
          harness is specified in downstream integration repositories; this
          document specifies the primitives it consumes.
        </description>
      </actor>
      <actor id="ACT-DEVELOPER" name="Toolchain User" type="human">
        <description>
          A developer who runs the rqml CLI locally and in CI to validate,
          inspect, and gate an RQML-governed project.
        </description>
      </actor>
    </actors>

    <stakeholders>
      <stakeholder id="STK-MAINTAINER" name="RQML Maintainer" org="rqml.org">
        <concerns>
          A coherent, backward-compatible standard that stays small, legible,
          and faithful to requirements-engineering theory.
        </concerns>
      </stakeholder>
      <stakeholder id="STK-TEAMS" name="Adopting Teams">
        <concerns>
          Low-ceremony requirements that materially improve LLM-assisted
          development without becoming a second job to maintain.
        </concerns>
      </stakeholder>
      <stakeholder id="STK-TOOLBUILDERS" name="Tool Builders">
        <concerns>
          A stable, validatable, extensible schema they can build editors,
          validators, and generators against.
        </concerns>
      </stakeholder>
    </stakeholders>

    <constraints>
      <constraint id="CON-XML" severity="blocking">
        <statement>RQML documents MUST be well-formed XML 1.0.</statement>
        <source>RQML design principle: documents, not data.</source>
      </constraint>
      <constraint id="CON-XSD" severity="blocking">
        <statement>
          A conforming RQML document MUST validate against the published XSD for
          its declared version (namespace https://rqml.org/schema/&lt;version&gt;).
        </statement>
        <source>packages/schema/versions/2.2.0/rqml-2.2.0.xsd</source>
      </constraint>
      <constraint id="CON-HUMAN-READABLE" severity="high">
        <statement>
          The format MUST remain human-readable and diff-friendly so teams will
          actually adopt and review it in pull requests.
        </statement>
        <source>why-rqml: low ongoing effort.</source>
      </constraint>
      <constraint id="CON-BACKWARD-COMPAT" severity="high">
        <statement>
          Minor version increments MUST be additive and backward compatible:
          documents valid under an earlier 2.x version MUST remain valid.
        </statement>
        <source>RFC-0002 compatibility section; changelog.</source>
      </constraint>
      <constraint id="CON-TYPESCRIPT" severity="high">
        <statement>
          The reference toolchain (core, CLI, MCP) SHALL be implemented in
          TypeScript on Node.js.
        </statement>
        <source>Architecture decision DEC-MONOREPO.</source>
      </constraint>
      <constraint id="CON-OFFLINE" severity="high">
        <statement>
          Validation and checking SHALL operate with no network access; the schema
          SHALL be resolved from a bundled copy, not fetched at runtime.
        </statement>
        <source>Reliability requirement for editor- and CI-time execution.</source>
      </constraint>
      <constraint id="CON-DETERMINISTIC-GATE" severity="blocking">
        <statement>
          The enforcement gate SHALL be deterministic: it SHALL NOT depend on a
          language model or any other nondeterministic component for its verdict.
        </statement>
        <source>Architecture decision DEC-DETERMINISTIC-CHECK.</source>
      </constraint>
    </constraints>

    <policies>
      <policy id="POL-RFC2119" source="RFC 2119 / RFC 8174">
        <obligation>
          Normative statements MUST use RFC 2119 keywords with their standard
          interpretation, surfaced through the RQML PriorityType vocabulary.
        </obligation>
        <evidence>meta/conventions/normativeKeywords; PriorityType enumeration.</evidence>
      </policy>
      <policy id="POL-SEMVER" source="Semantic Versioning 2.0.0">
        <obligation>
          Schema versions MUST follow semantic versioning: additive changes bump
          the minor version; breaking changes bump the major version.
        </obligation>
        <evidence>changelog: 2.0.1 -&gt; 2.1.0 (additive trace + behavior changes).</evidence>
      </policy>
    </policies>

    <decisions>
      <decision id="DEC-XML" status="approved">
        <context>
          The format must be read carefully and reliably by LLM coding agents
          and remain legible to humans at multi-thousand-requirement scale.
        </context>
        <decision>
          Use XML. Tag pairs are explicit, tag names carry semantic weight, and
          XML is heavily represented in foundation-model training corpora, so
          LLMs read it more reliably than JSON or YAML.
        </decision>
        <alternatives>
          JSON/YAML/TOML — rejected: they model data records, not documents, and
          cannot cleanly represent mixed content.
        </alternatives>
        <consequences>
          More verbose for tiny examples; closing tags cost tokens. These costs
          are paid up front and amortized over the artifact's life. Gains:
          schema validation, namespaces, comments, and clean diffs.
        </consequences>
      </decision>
      <decision id="DEC-DOCUMENT-ORIENTED" status="approved">
        <context>
          A requirements spec is long-form natural language with structured
          metadata, cross-references, scenarios, and rationale.
        </context>
        <decision>
          Treat RQML as a document format (like DocBook, DITA, OOXML, ePub),
          centering mixed content rather than flat typed records.
        </decision>
        <consequences>Statements can interleave prose and structured elements.</consequences>
      </decision>
      <decision id="DEC-MIXED-CONTENT" status="approved">
        <context>
          Requirement statements need embedded references and measurements
          inside prose without losing either the structure or the sentence.
        </context>
        <decision>
          Model narrative-bearing elements as a mixed TextBlockType that allows
          text interleaved with lax-processed child elements.
        </decision>
        <consequences>
          Authors and tools can embed inline references/units; JSON/YAML could
          not express this cleanly.
        </consequences>
      </decision>
      <decision id="DEC-TRACE-ENDPOINTS" status="approved">
        <context>
          Traceability must support same-document, cross-document, and external
          targets, with immutability for cross-document references.
        </context>
        <decision>
          In 2.1.0, model trace as edge elements with structured from/to
          endpoints, each holding a locator of kind local, doc, or external;
          doc locators support version and git pinning.
        </decision>
        <alternatives>
          The 2.0.1 traceEdge with flat from/to attributes plus fromUri/toUri —
          superseded for weaker cross-document and external semantics.
        </alternatives>
        <consequences>
          Local locators are keyref-validated; doc and external locators are not
          schema-validated but enable cross-project and tool integration.
        </consequences>
      </decision>
      <decision id="DEC-BEHAVIOR-FLAT" status="approved">
        <context>
          Many entities have well-defined lifecycles that prose specifies
          ambiguously, blocking reliable code and test generation (RFC-0002).
        </context>
        <decision>
          Add an optional behavior section with flat finite state machines
          (states + transitions, guards, actions), deliberately excluding full
          UML statechart semantics.
        </decision>
        <alternatives>
          Embedding states in entities, reusing scenarios, full UML statecharts,
          or external SCXML/XState references — all rejected in RFC-0002.
        </alternatives>
        <consequences>
          Flat, LLM-interpretable lifecycles; hierarchical/parallel states are
          deferred to a future RFC.
        </consequences>
      </decision>
      <decision id="DEC-MONOREPO" status="review">
        <context>
          The schema, documentation, and a reference implementation (validation,
          CLI, and agent integration) must evolve together while remaining
          independently consumable.
        </context>
        <decision>
          Develop the toolchain as a single TypeScript pnpm workspace in the rqml
          repository, with publishable packages @rqml/core, the rqml CLI, and
          @rqml/mcp under packages/, the canonical XSDs in a schema package, and
          the documentation site as an app.
        </decision>
        <alternatives>
          Separate repositories per component (rejected: cross-cutting schema
          changes would ripple across repos); a single bundled package (rejected:
          editors and agent integrations would inherit CLI and MCP dependencies).
        </alternatives>
        <consequences>
          One source of truth and atomic changes, at the cost of workspace
          tooling. @rqml/core is kept dependency-clean so it can be embedded
          without the CLI or MCP SDK.
        </consequences>
      </decision>
      <decision id="DEC-DETERMINISTIC-CHECK" status="review">
        <context>
          Earlier tooling compared the spec to code using a language model. A
          nondeterministic comparison cannot serve as a reproducible enforcement
          gate or as audit evidence, and is too slow to run on every save.
        </context>
        <decision>
          Make validation, coverage, and drift detection fully deterministic in
          @rqml/core. Confine language-model assistance to authoring and proposing
          content; the model proposes, the toolchain disposes.
        </decision>
        <alternatives>
          A model-backed gate (rejected: not reproducible, not auditable, slow,
          costly per turn).
        </alternatives>
        <consequences>
          Identical inputs yield identical verdicts, enabling trustworthy gates
          and append-only audit trails; semantic fidelity checks become an
          optional, pluggable pass rather than the load-bearing comparison.
        </consequences>
      </decision>
      <decision id="DEC-EXPLICIT-TRACE" status="review">
        <context>
          Deterministic drift detection requires machine-resolvable links between
          requirements and the code that realizes them.
        </context>
        <decision>
          Represent implementation links explicitly as implements trace edges
          whose endpoints use external locators (file, symbol, or test URIs),
          rather than inferring the mapping semantically.
        </decision>
        <consequences>
          Coverage and drift become graph, filesystem, and AST operations the
          engine can compute offline and reproducibly.
        </consequences>
      </decision>
      <decision id="DEC-SCHEMA-PACKAGE" status="review">
        <context>
          The XSD is consumed by the engine, bundled by the CLI and MCP server,
          and published to stable rqml.org URLs referenced by every document's
          schemaLocation.
        </context>
        <decision>
          Keep a single canonical copy of every schema version in the schema
          package; all consumers obtain it from there, and the documentation site
          publishes it to its stable versioned URLs.
        </decision>
        <consequences>
          No hand-maintained duplicate schemas can drift from the canonical
          source; the published-URL contract is generated, not copied.
        </consequences>
      </decision>
      <decision id="DEC-VERSION-DECOUPLE" status="review">
        <context>
          The RQML language version (e.g. 2.2.0) and the npm package versions of
          the toolchain change at very different rates.
        </context>
        <decision>
          Version the RQML spec independently of the toolchain package versions;
          the schema package may hold several spec versions simultaneously.
        </decision>
        <consequences>
          Engine patches do not perturb the language version, and old documents
          keep validating after new schema versions ship.
        </consequences>
      </decision>
      <decision id="DEC-FIVE-STAGE" status="approved">
        <context>
          The spec-first loop was historically described as
          Elicit-Specify-Implement-Verify-Trace, which collapsed architecture and
          planning into "implement" and left design decisions undocumented. The
          VS Code extension proved a fuller five-stage shape — Spec, Design, Plan,
          Code, Verify — with ADRs and a plan file as first-class artifacts.
        </context>
        <decision>
          Adopt the five-stage Spec-Design-Plan-Code-Verify process as the
          standard RQML development process: design decisions recorded as ADRs in
          .rqml/adr/, the implementation plan in .rqml/plan.md. Promote the
          definition into the core rqml.org documentation; editor and
          coding-agent integrations supply the per-stage commands.
        </decision>
        <alternatives>
          Keep the four-stage loop (rejected: it hides the Design and Plan stages,
          the two points where involving a human before code is written pays off
          most). Make the deterministic check gate ADR/plan-aware (deferred:
          keeps a model out of the verdict path and avoids changing the gate's
          contract; see ISS-PROCESS-GATE).
        </alternatives>
        <consequences>
          The AGENTS.md template, the rqml.org docs, and downstream agent plugins
          teach the same five stages; the ADR and plan conventions are documented
          project-wide. The deterministic check gate is unchanged — ADR and plan
          adherence is guided by integrations, not gated by a model.
        </consequences>
      </decision>
    </decisions>

    <risks>
      <risk id="RISK-DRIFT" severity="high">
        <statement>
          The specification drifts out of sync with the implementation, becoming
          stale documentation that no one trusts.
        </statement>
        <mitigation>
          Spec-first process, traceability to code, CI sync checks, and diffable
          PR review keep the artifact alive.
        </mitigation>
      </risk>
      <risk id="RISK-VERBOSITY" severity="medium">
        <statement>
          XML verbosity discourages adoption, especially for small specs.
        </statement>
        <mitigation>
          Only meta and requirements are mandatory; authoring tooling (VS Code
          extension) and LLM assistance reduce mechanical friction.
        </mitigation>
      </risk>
      <risk id="RISK-AMBIGUITY" severity="high">
        <statement>
          Free-text statements and guards remain ambiguous, letting LLMs fill
          gaps with incorrect assumptions.
        </statement>
        <mitigation>
          Glossary terms, normative keywords, acceptance criteria, and metrics
          on quality goals reduce interpretive latitude.
        </mitigation>
      </risk>
      <risk id="RISK-LLM-GATE" severity="high">
        <statement>
          Relying on a nondeterministic language model to decide whether code
          matches the spec yields an unreliable, unauditable, and slow gate.
        </statement>
        <mitigation>Deterministic engine (REQ-CORE-NO-LLM); model confined to authoring.</mitigation>
      </risk>
      <risk id="RISK-SCHEMA-COPY" severity="medium">
        <statement>
          Hand-maintained duplicate copies of the XSD in multiple packages drift
          from the canonical schema, causing inconsistent validation.
        </statement>
        <mitigation>Single canonical schema package (REQ-SCHEMA-CANONICAL).</mitigation>
      </risk>
      <risk id="RISK-CORE-BLOAT" severity="medium">
        <statement>
          @rqml/core accretes CLI or MCP dependencies, becoming too heavy to embed
          in editors and agent integrations.
        </statement>
        <mitigation>Dependency-clean core boundary (REQ-CORE-DEPS).</mitigation>
      </risk>
    </risks>
  </catalogs>

  <!-- ============================================================= -->
  <!-- DOMAIN — the RQML metamodel (shape of an RQML document)       -->
  <!-- ============================================================= -->
  <domain>
    <overview>
      The RQML "domain" is the structure of an RQML document itself. The
      entities below model the metamodel: the document root and its principal
      element types. Business rules capture the invariants the XSD enforces.
    </overview>
    <entities>
      <entity id="ENT-DOC" name="RqmlDocument">
        <description>The root rqml element and container for all sections.</description>
        <attr id="ATTR-DOC-VERSION" name="version" type="enum:2.2.0" required="true">
          <description>Schema version.</description>
          <constraints>Fixed to "2.2.0" for the current schema generation; each generation pins its own value (BR-VERSION-FIXED).</constraints>
        </attr>
        <attr id="ATTR-DOC-ID" name="docId" type="string" required="true">
          <description>Stable, unique document identifier.</description>
          <constraints>Matches IdType: [A-Za-z][A-Za-z0-9._-]*, length 2–80.</constraints>
        </attr>
        <attr id="ATTR-DOC-STATUS" name="status" type="enum:draft,review,approved,deprecated" required="true">
          <description>Document lifecycle state.</description>
        </attr>
      </entity>
      <entity id="ENT-REQ" name="Requirement">
        <description>The fundamental normative unit, classified by ReqType.</description>
        <attr id="ATTR-REQ-TYPE" name="type" type="enum:FR,NFR,IR,DR,SR,CR,PR,UXR,OR" required="true">
          <description>Requirement classification.</description>
        </attr>
        <attr id="ATTR-REQ-PRIORITY" name="priority" type="enum:must,should,may" required="false">
          <description>MoSCoW priority.</description>
        </attr>
        <attr id="ATTR-REQ-STATEMENT" name="statement" type="TextBlock" required="true">
          <description>The normative statement, using RFC 2119 keywords.</description>
        </attr>
      </entity>
      <entity id="ENT-GOAL" name="Goal">
        <description>An intentional objective the system exists to achieve.</description>
        <attr id="ATTR-GOAL-STATEMENT" name="statement" type="TextBlock" required="true">
          <description>Desired state of the world.</description>
        </attr>
      </entity>
      <entity id="ENT-SM" name="StateMachine">
        <description>A flat finite state machine over an entity or process.</description>
        <attr id="ATTR-SM-INITIAL" name="initial" type="IdRef" required="true">
          <description>Reference to the single initial state.</description>
        </attr>
      </entity>
      <entity id="ENT-STATE" name="State">
        <description>A mutually exclusive condition in a lifecycle.</description>
        <attr id="ATTR-STATE-KIND" name="type" type="enum:initial,normal,final" required="false">
          <description>State kind; defaults to normal.</description>
        </attr>
      </entity>
      <entity id="ENT-TRANSITION" name="Transition">
        <description>A valid directed movement between two states.</description>
        <attr id="ATTR-TR-FROM" name="from" type="IdRef" required="true">
          <description>Source state.</description>
        </attr>
        <attr id="ATTR-TR-TO" name="to" type="IdRef" required="true">
          <description>Target state.</description>
        </attr>
      </entity>
      <entity id="ENT-TRACE-EDGE" name="TraceEdge">
        <description>A typed, directed relationship between two endpoints.</description>
        <attr id="ATTR-EDGE-TYPE" name="type" type="TraceType" required="true">
          <description>Relationship type (15 values).</description>
        </attr>
        <attr id="ATTR-EDGE-CONFIDENCE" name="confidence" type="decimal" required="false">
          <description>Strength of the relationship, 0.0–1.0.</description>
        </attr>
      </entity>
      <entity id="ENT-LOCATOR" name="Locator">
        <description>An endpoint reference: local, doc, or external.</description>
        <attr id="ATTR-LOC-KIND" name="kind" type="enum:local,doc,external" required="true">
          <description>Which locator variant is used.</description>
        </attr>
      </entity>
      <entity id="ENT-CRITERION" name="AcceptanceCriterion">
        <description>A given/when/then testable condition for a requirement.</description>
        <attr id="ATTR-CRIT-THEN" name="then" type="TextBlock" required="true">
          <description>The verifiable expected outcome.</description>
        </attr>
      </entity>
      <entity id="ENT-CORE" name="Core Engine">
        <description>The @rqml/core library: parsing, validation, trace graph, coverage, and drift.</description>
        <attr id="ATTR-CORE-PURE" name="dependencyClean" type="boolean" required="true">
          <description>Carries no CLI or MCP runtime dependencies.</description>
        </attr>
      </entity>
      <entity id="ENT-CLI" name="Command-Line Interface">
        <description>The rqml executable: init, validate, status, and check commands.</description>
        <attr id="ATTR-CLI-EXIT" name="exitCode" type="integer" required="true">
          <description>Documented, stable process exit code per outcome class.</description>
        </attr>
      </entity>
      <entity id="ENT-MCP" name="MCP Server">
        <description>The @rqml/mcp server exposing core capabilities as agent tools.</description>
      </entity>
      <entity id="ENT-CHECK-REPORT" name="Check Report">
        <description>The deterministic result of rqml check: validity, coverage, and drift findings, in stable JSON.</description>
        <attr id="ATTR-REPORT-VERDICT" name="verdict" type="enum:pass,fail" required="true">
          <description>Whether the project passes the enforcement gate.</description>
        </attr>
      </entity>
      <entity id="ENT-IMPL-LINK" name="Implementation Link">
        <description>An implements trace edge from a code artifact to the requirement it realizes.</description>
        <attr id="ATTR-LINK-TARGET" name="targetUri" type="anyURI" required="true">
          <description>External locator of the implementing artifact (file, symbol, or test).</description>
        </attr>
      </entity>
    </entities>
    <businessRules>
      <rule id="BR-UNIQUE-ID">
        <statement>Every @id in a document MUST be unique across all elements.</statement>
        <examples>The XSD allIds key enforces this over every referenceable element.</examples>
      </rule>
      <rule id="BR-TRACE-INTEGRITY">
        <statement>
          Every local trace locator MUST reference a declared @id in the same document.
        </statement>
        <examples>
          traceFromRef / traceToRef keyrefs fail validation for dangling local references.
        </examples>
      </rule>
      <rule id="BR-REQUIRED-SECTIONS">
        <statement>A document MUST contain meta and requirements; all other sections are optional.</statement>
      </rule>
      <rule id="BR-SECTION-ORDER">
        <statement>
          Sections MUST appear in the fixed order: meta, catalogs, domain, goals,
          scenarios, requirements, behavior, interfaces, verification, trace, governance.
        </statement>
      </rule>
      <rule id="BR-SINGLE-INITIAL">
        <statement>
          A state machine MUST declare exactly one initial state, referenced by @initial.
        </statement>
        <examples>smInitialRef keyref resolves @initial to a declared state.</examples>
      </rule>
      <rule id="BR-FINAL-NO-OUT">
        <statement>States of type "final" MUST NOT have outgoing transitions.</statement>
      </rule>
      <rule id="BR-VERSION-FIXED">
        <statement>The root @version MUST equal the schema generation the document declares, and the default namespace MUST be the matching https://rqml.org/schema/&lt;version&gt; URI.</statement>
      </rule>
      <rule id="BR-CORE-PURE">
        <statement>@rqml/core MUST NOT declare CLI argument-parsing or MCP SDK packages as runtime dependencies.</statement>
        <examples>Verified by inspecting the published package's dependency tree.</examples>
      </rule>
      <rule id="BR-CHECK-DETERMINISTIC">
        <statement>Running rqml check twice on the same document and codebase MUST produce the same verdict and findings.</statement>
      </rule>
      <rule id="BR-GATE-EXIT">
        <statement>rqml check MUST exit zero only when the document is valid and no blocking drift or coverage violation exists.</statement>
      </rule>
    </businessRules>
  </domain>

  <!-- ============================================================= -->
  <!-- GOALS                                                         -->
  <!-- ============================================================= -->
  <goals>
    <goal id="GOAL-PRIMARY-ARTIFACT" title="Requirements as the primary artifact" priority="must" ownerRef="STK-MAINTAINER">
      <statement>
        Make requirements — not code — the authoritative, durable source of
        truth for system intent.
      </statement>
      <rationale>
        Code derived from a stable specification is calmer, more consistent, and
        easier to evolve and verify than code generated from a chat thread.
      </rationale>
    </goal>
    <goal id="GOAL-LLM-CONTEXT" title="Legible long-term LLM context" priority="must" ownerRef="STK-TEAMS">
      <statement>
        Package project context so generation is "code from a specification,"
        reducing invented assumptions and missed non-functional requirements.
      </statement>
      <rationale>
        LLMs amplify weak requirements; explicit, structured context grounds them.
      </rationale>
    </goal>
    <goal id="GOAL-LOW-CEREMONY" title="Low-ceremony requirements engineering" priority="must" ownerRef="STK-TEAMS">
      <statement>
        Make good requirements cheap enough to be worth doing — enough discipline
        to be useful without becoming a second job.
      </statement>
      <rationale>
        Teams shortcut RE when the perceived cost exceeds the benefit; lowering
        cost is the central economic thesis of RQML.
      </rationale>
    </goal>
    <goal id="GOAL-TRACEABILITY" title="End-to-end traceability" priority="must" ownerRef="STK-MAINTAINER">
      <statement>
        Connect goals to requirements to behavior to verification to code so
        teams can prove what they built matches intent.
      </statement>
      <rationale>Traceability enables impact analysis and coverage analysis.</rationale>
    </goal>
    <goal id="GOAL-RE-OPERATIONALIZE" title="Operationalize RE best practice" priority="should" ownerRef="STK-MAINTAINER">
      <statement>
        Reflect IEEE 29148, ISO/IEC 25010, KAOS/i*, Volere, and BDD practices in
        a format both humans and tools can reliably process.
      </statement>
    </goal>

    <goal id="GOAL-ENFORCEMENT" title="Deterministic spec enforcement" priority="must" ownerRef="STK-TEAMS">
      <statement>
        Make the spec-first process enforceable by deterministic tooling so a
        coding agent keeps working from the RQML spec for the life of a project
        without relying on the model remembering to.
      </statement>
      <rationale>
        Agents drift because the process is voluntary; moving enforcement into
        deterministic checks removes reliance on attention and memory.
      </rationale>
    </goal>
    <goal id="GOAL-REUSABLE-ENGINE" title="One reusable engine" priority="must" ownerRef="STK-TOOLBUILDERS">
      <statement>
        Provide a single validation, trace, and check engine that the CLI, the
        MCP server, editors, and agent integrations all reuse.
      </statement>
      <rationale>One engine means one source of truth for verdicts across every surface.</rationale>
    </goal>
    <goal id="GOAL-OFFLINE-FAST" title="Fast, offline, reproducible tooling" priority="should" ownerRef="STK-TOOLBUILDERS">
      <statement>
        Make validation and checking fast and fully offline so they can run on
        every editor save, agent turn, and CI job.
      </statement>
    </goal>

    <qgoal id="QGOAL-LLM-READ" title="LLM read reliability" priority="must">
      <statement>The format SHOULD be the format LLMs parse most reliably.</statement>
      <metric>
        Explicit paired tags and semantic element names; no reliance on
        whitespace or positional structure for meaning.
      </metric>
    </qgoal>
    <qgoal id="QGOAL-VALIDATABLE" title="Schema validatability" priority="must">
      <statement>Structural invariants SHALL be machine-checkable.</statement>
      <metric>
        100% of ID-uniqueness, trace-resolution, and state-machine-reference
        invariants enforced by the XSD without external tooling.
      </metric>
    </qgoal>
    <qgoal id="QGOAL-DIFF" title="Diff-friendliness" priority="should">
      <statement>Documents SHOULD diff cleanly in version control.</statement>
      <metric>
        No whitespace-significant structure; reordering or reformatting does not
        change document meaning.
      </metric>
    </qgoal>
    <qgoal id="QGOAL-HUMAN" title="Human readability" priority="must">
      <statement>The format SHALL remain readable and reviewable by humans.</statement>
      <metric>A minimal valid document is expressible in under 15 lines.</metric>
    </qgoal>

    <qgoal id="QGOAL-DETERMINISTIC" title="Deterministic verdicts" priority="must">
      <statement>The enforcement gate SHALL return identical verdicts for identical inputs.</statement>
      <metric>100% reproducibility of rqml check verdicts across repeated runs and machines.</metric>
    </qgoal>
    <qgoal id="QGOAL-CHECK-SPEED" title="Interactive check latency" priority="should">
      <statement>Validation and checking SHOULD be fast enough for interactive use.</statement>
      <metric>rqml check and rqml status complete in under ~1s on a typical project.</metric>
    </qgoal>

    <obstacle id="OBS-DRIFT" title="Specification drift" likelihood="high" severity="high">
      <statement>The spec decays into stale documentation disconnected from code.</statement>
      <mitigation>Spec-first workflow, trace-to-code, and CI sync checks.</mitigation>
    </obstacle>
    <obstacle id="OBS-COST" title="Perceived RE cost" likelihood="medium" severity="high">
      <statement>Teams perceive requirements work as heavyweight and skip it.</statement>
      <mitigation>Minimal mandatory structure plus LLM-assisted authoring.</mitigation>
    </obstacle>
    <obstacle id="OBS-AMBIGUITY" title="Residual ambiguity" likelihood="medium" severity="high">
      <statement>Free text leaves room for divergent interpretation.</statement>
      <mitigation>Glossary, normative keywords, metrics, and acceptance criteria.</mitigation>
    </obstacle>

    <obstacle id="OBS-VOLUNTARY" title="Voluntary compliance fails" likelihood="high" severity="high">
      <statement>
        Coding agents forget that a project is RQML-governed and stop maintaining
        the spec, because nothing deterministic enforces the process.
      </statement>
      <mitigation>Deterministic check gate, status re-anchoring, and drift detection.</mitigation>
    </obstacle>

    <goalLink id="GL-LLM-REFINES-PRIMARY" from="GOAL-LLM-CONTEXT" to="GOAL-PRIMARY-ARTIFACT" type="refines" confidence="0.9"/>
    <goalLink id="GL-RE-REFINES-LOW" from="GOAL-RE-OPERATIONALIZE" to="GOAL-LOW-CEREMONY" type="refines" confidence="0.8"/>
    <goalLink id="GL-DRIFT-THREATENS" from="OBS-DRIFT" to="GOAL-PRIMARY-ARTIFACT" type="threatens" confidence="0.9"/>
    <goalLink id="GL-COST-THREATENS" from="OBS-COST" to="GOAL-LOW-CEREMONY" type="threatens" confidence="0.8"/>
    <goalLink id="GL-AMBIGUITY-THREATENS" from="OBS-AMBIGUITY" to="GOAL-LLM-CONTEXT" type="threatens" confidence="0.8"/>
    <goalLink id="GL-VOLUNTARY-THREATENS" from="OBS-VOLUNTARY" to="GOAL-ENFORCEMENT" type="threatens" confidence="0.9"/>
    <goalLink id="GL-ENFORCE-REFINES-PRIMARY" from="GOAL-ENFORCEMENT" to="GOAL-PRIMARY-ARTIFACT" type="refines" confidence="0.85"/>
    <goalLink id="GL-ENGINE-REFINES-ENFORCE" from="GOAL-REUSABLE-ENGINE" to="GOAL-ENFORCEMENT" type="refines" confidence="0.7"/>
  </goals>

  <!-- ============================================================= -->
  <!-- SCENARIOS                                                     -->
  <!-- ============================================================= -->
  <scenarios>
    <scenario id="SCN-AUTHOR" title="Authoring a specification" actorRef="ACT-AUTHOR">
      <narrative>
        1. An author (often with an LLM) creates one spec file — conventionally
           requirements.rqml — and its co-located .rqml/ directory in that same
           directory, at the root of the subtree it governs. The spec governs that
           directory and every subdirectory beneath it, until a nested spec takes
           over its own subtree; it never governs a parent directory.
        2. They populate meta and at least one requirement.
        3. They grow the spec — goals, scenarios, domain, behavior — as the system grows.
        4. The schema validator confirms structural validity on save and in CI.
      </narrative>
    </scenario>
    <scenario id="SCN-CODEGEN" title="Generating code from the spec" actorRef="ACT-LLM">
      <narrative>
        1. The agent reads domain entities, business rules, and behavior for data models.
        2. It reads FR/IR/DR/SR requirements for features, contracts, and validation.
        3. It generates code consistent with constraints and approved decisions.
        4. It records implements trace edges back to the requirements.
      </narrative>
    </scenario>
    <scenario id="SCN-TESTGEN" title="Generating tests from acceptance criteria" actorRef="ACT-LLM">
      <narrative>
        1. The agent reads given/when/then acceptance criteria and quality-goal metrics.
        2. It generates acceptance, unit, integration, performance, and security tests.
        3. It records verifiedBy/covers trace edges to the requirements.
      </narrative>
    </scenario>
    <scenario id="SCN-IMPACT" title="Impact and coverage analysis" actorRef="ACT-TOOLING">
      <narrative>
        1. Tooling queries the trace graph for edges touching a changing artifact.
        2. It follows edges transitively, weighted by confidence, to find impacts.
        3. It flags goals with no satisfies edges as uncovered.
      </narrative>
    </scenario>
    <misuseCase id="MIS-GHOST" title="Unspecified implementation (ghost feature)" actorRef="ACT-LLM">
      <narrative>
        An agent implements behavior with no corresponding approved requirement.
        Under stricter levels this is rejected; the missing requirement must be
        captured before or alongside the code.
      </narrative>
    </misuseCase>
    <edgeCase id="EDGE-MINIMAL" title="Minimal valid document" actorRef="ACT-AUTHOR">
      <narrative>
        A document containing only meta (title, system) and a single requirement
        is valid and useful — RQML scales down as well as up.
      </narrative>
    </edgeCase>
  </scenarios>

  <!-- ============================================================= -->
  <!-- REQUIREMENTS                                                  -->
  <!-- ============================================================= -->
  <requirements>

    <reqPackage id="PKG-STRUCTURE" title="Document structure" ownerRef="STK-MAINTAINER">
      <description>Rules governing the shape, identity, and ordering of an RQML document.</description>
      <req id="REQ-DOC-ROOT" type="DR" title="Document root" status="approved" priority="must">
        <statement>
          A conforming document SHALL have a single rqml root element declaring
          the RQML namespace and carrying version, docId, and status attributes.
        </statement>
      </req>
      <req id="REQ-VERSION" type="CR" title="Fixed version" status="approved" priority="must">
        <statement>
          Each schema generation SHALL fix the root version attribute to the
          generation it defines, and a document's default namespace SHALL be the
          matching https://rqml.org/schema/&lt;version&gt; URI. The two SHALL never
          disagree.
        </statement>
        <rationale>
          Binds a document to a specific, immutable schema generation. The
          obligation is that version and namespace agree and name a published
          generation — not any one value. Naming a literal here made this
          requirement assert "2.1.0" from inside a 2.2.0 document, so the
          language's own self-description contradicted itself for an entire
          release. The current generation is carried by ATTR-DOC-VERSION and
          enforced mechanically by the XSD's fixed attribute.
        </rationale>
      </req>
      <req id="REQ-REQUIRED-SECTIONS" type="DR" title="Required sections" status="approved" priority="must">
        <statement>
          A document SHALL contain a meta section and a requirements section; all
          other sections MAY be omitted.
        </statement>
        <acceptance>
          <criterion id="CRIT-MIN-DOC">
            <given>A document with only meta (title, system) and one req</given>
            <when>It is validated against the XSD</when>
            <then>Validation succeeds.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SECTION-ORDER" type="DR" title="Fixed section order" status="approved" priority="must">
        <statement>
          Sections SHALL appear in the order: meta, catalogs, domain, goals,
          scenarios, requirements, behavior, interfaces, verification, trace, governance.
        </statement>
      </req>
      <req id="REQ-ID-UNIQUE" type="DR" title="Unique identifiers" status="approved" priority="must">
        <statement>
          Every id attribute SHALL be unique across the entire document.
        </statement>
        <acceptance>
          <criterion id="CRIT-DUP-ID">
            <given>Two elements sharing the same id</given>
            <when>The document is validated</when>
            <then>Validation fails on the allIds key constraint.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-ID-PATTERN" type="DR" title="Identifier format" status="approved" priority="must">
        <statement>
          Identifiers SHALL match the pattern [A-Za-z][A-Za-z0-9._-]* and be
          2–80 characters long.
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-VOCAB" title="Controlled vocabularies" ownerRef="STK-MAINTAINER">
      <description>The enumerated value sets that constrain RQML attributes.</description>
      <req id="REQ-STATUS-ENUM" type="DR" title="Lifecycle status vocabulary" status="approved" priority="must">
        <statement>
          Artifact status SHALL be one of: draft, review, approved, deprecated.
          Only approved artifacts SHOULD drive implementation.
        </statement>
      </req>
      <req id="REQ-PRIORITY-ENUM" type="DR" title="Priority vocabulary" status="approved" priority="must">
        <statement>
          Priority SHALL be one of must, should, or may, interpreted per RFC 2119.
        </statement>
      </req>
      <req id="REQ-REQTYPE-ENUM" type="DR" title="Requirement-type vocabulary" status="approved" priority="must">
        <statement>
          A requirement SHALL declare a type from: FR, NFR, IR, DR, SR, CR, PR,
          UXR, OR.
        </statement>
        <notes>The type guides which implementation approach an agent applies.</notes>
      </req>
      <req id="REQ-TRACETYPE-ENUM" type="DR" title="Trace-type vocabulary" status="approved" priority="must">
        <statement>
          A trace edge SHALL declare a type from the 15-value TraceType set,
          including refines, satisfies, dependsOn, verifiedBy, mitigates,
          implements, supersedes, conformsTo, deprecates, and breaks.
        </statement>
      </req>
      <req id="REQ-TESTTYPE-ENUM" type="DR" title="Test-type vocabulary" status="approved" priority="should">
        <statement>
          A test case SHALL declare a type from: acceptance, integration, unit,
          security, performance, inspection.
        </statement>
      </req>
      <req id="REQ-CONFIDENCE-RANGE" type="DR" title="Confidence range" status="approved" priority="should">
        <statement>
          Confidence values on trace edges and goal links SHALL be decimals in
          the inclusive range 0.0 to 1.0.
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-TRACE" title="Traceability model" ownerRef="STK-MAINTAINER">
      <description>
        The trace graph: a structured-endpoint model (2.1.0) serialized in
        compact attribute form from 2.2.0 (RFC-0003).
      </description>
      <req id="REQ-TRACE-EDGE" type="FR" title="Typed trace edges" status="approved" priority="must">
        <statement>
          The trace section SHALL express relationships as edge elements, each
          with exactly one from and one to endpoint and a TraceType.
        </statement>
      </req>
      <req id="REQ-TRACE-LOCATORS" type="FR" title="Three locator kinds" status="approved" priority="must">
        <statement>
          Each trace endpoint SHALL resolve to exactly one locator kind: local
          (same document), doc (another RQML document), or external (any URI).
        </statement>
      </req>
      <req id="REQ-TRACE-COMPACT" type="FR" title="Compact edge serialization" status="approved" priority="must">
        <statement>
          From schema version 2.2.0 the edge SHALL serialize its endpoints as
          required from and to attributes carrying a lexically discriminated
          micro-syntax — a bare id is local, an rqml: URI whose fragment is the
          target id followed by optional semicolon-separated version/git/docId
          pins is doc, and any other scheme URI or schemeless relative path
          containing a slash is external — with locator hints as
          fromKind/fromTitle/toKind/toTitle attributes. This is the only edge
          form in 2.2.0; the 2.1.0 nested endpoint elements are removed
          (RFC-0003).
        </statement>
        <rationale>
          Trace edges measured 32.1% of all spec bytes across the dogfood
          corpus, almost entirely endpoint scaffolding that encodes one bit
          (locator kind) per 44 bytes. The compact form cuts edge bytes 43%
          losslessly. One canonical form avoids a permanent two-dialect
          standard (RFC-0003, ADR-0017).
        </rationale>
        <acceptance>
          <criterion id="CRIT-COMPACT-LOSSLESS">
            <given>Any 2.1.0 trace edge (local, doc with version/git/docId pins, or external, with hints and notes)</given>
            <when>It is re-expressed in the 2.2.0 compact form and parsed</when>
            <then>The parsed TraceEdge model is identical to the 2.1.0 parse.</then>
          </criterion>
          <criterion id="CRIT-COMPACT-REQUIRED">
            <given>A 2.2.0 edge missing its from or to attribute, or carrying a malformed endpoint value</given>
            <when>The document is validated against the 2.2.0 schema</when>
            <then>Validation fails.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-TRACE-INTEGRITY" type="DR" title="Local reference integrity" status="approved" priority="must">
        <statement>
          Every local trace endpoint SHALL resolve to a declared id in the same
          document; dangling local references SHALL fail the toolchain's
          validation. A conforming processor MUST enforce id-uniqueness and
          local-reference resolution itself; XSD validation alone is not
          conformance (RFC-0003).
        </statement>
        <acceptance>
          <criterion id="CRIT-DANGLING">
            <given>An edge whose local endpoint id does not exist, in either the 2.1.0 nested or 2.2.0 compact form</given>
            <when>The document is checked</when>
            <then>The integrity checker reports an unresolved local reference.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-TRACE-PINNING" type="IR" title="Cross-document pinning" status="approved" priority="should">
        <statement>
          Doc locators SHALL support optional version and git pins so
          cross-document references can be pinned for immutability, in both the
          2.1.0 attribute form and the 2.2.0 fragment micro-syntax.
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-BEHAVIOR" title="Behavior modeling" ownerRef="STK-MAINTAINER">
      <description>Flat finite state machines for entity and process lifecycles (RFC-0002).</description>
      <req id="REQ-SM" type="FR" title="State machines" status="approved" priority="should">
        <statement>
          The optional behavior section SHALL allow state machines composed of
          states and transitions with optional guards, actions, and entity references.
        </statement>
      </req>
      <req id="REQ-SM-INITIAL" type="DR" title="Single initial state" status="approved" priority="must">
        <statement>
          Each state machine SHALL reference exactly one declared initial state
          via its initial attribute.
        </statement>
        <acceptance>
          <criterion id="CRIT-SM-INIT">
            <given>A stateMachine whose @initial names an undeclared state</given>
            <when>The document is validated</when>
            <then>Validation fails on the smInitialRef keyref.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SM-FINAL" type="DR" title="Terminal final states" status="approved" priority="should">
        <statement>
          States declared with type "final" SHALL NOT have outgoing transitions.
        </statement>
      </req>
      <req id="REQ-TRANSITION-REFS" type="DR" title="Resolvable transitions" status="approved" priority="must">
        <statement>
          Each transition from and to attribute SHALL resolve to a declared state.
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-FORMAT" title="Format and extensibility" ownerRef="STK-TOOLBUILDERS">
      <description>The XML-foundation requirements that make RQML a document format.</description>
      <req id="REQ-XML" type="CR" title="Well-formed XML" status="approved" priority="must">
        <statement>An RQML document SHALL be well-formed XML 1.0.</statement>
        <rationale>LLMs read XML most reliably and it models documents, not data.</rationale>
      </req>
      <req id="REQ-MIXED-CONTENT" type="FR" title="Mixed content" status="approved" priority="must">
        <statement>
          Narrative-bearing elements SHALL permit mixed content: natural-language
          prose interleaved with structured child elements.
        </statement>
      </req>
      <req id="REQ-NAMESPACE" type="IR" title="Namespaced extensibility" status="approved" priority="should">
        <statement>
          The format SHALL use XML namespaces so third parties MAY extend RQML
          without forking the standard.
        </statement>
      </req>
      <req id="REQ-COMMENTS" type="FR" title="Author annotations" status="approved" priority="may">
        <statement>
          The format SHALL allow non-content author annotations (XML comments).
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-PROCESS" title="Spec-first development process" ownerRef="STK-TEAMS">
      <description>How RQML is meant to be used in an LLM-assisted workflow.</description>
      <req id="REQ-SPEC-FIRST" type="PR" title="Spec-first development" status="approved" priority="must">
        <statement>
          Features SHALL be specified in RQML before implementation; code SHOULD
          trace back to an approved requirement.
        </statement>
        <rationale>Prevents ghost features and keeps the spec authoritative.</rationale>
      </req>
      <req id="REQ-STRICTNESS" type="PR" title="Configurable strictness" status="approved" priority="should">
        <statement>
          The process SHALL support configurable strictness levels — relaxed,
          standard, strict, and certified — that scale enforcement and required
          trace metadata to the project's risk profile.
        </statement>
      </req>
      <req id="REQ-NORMATIVE-KEYWORDS" type="CR" title="RFC 2119 statements" status="approved" priority="must">
        <statement>
          Requirement statements SHALL use RFC 2119 normative keywords so
          obligation levels are unambiguous.
        </statement>
      </req>
      <req id="REQ-AGENTS-TEMPLATE" type="PR" title="Template teaches the process and routes agents to the toolchain" status="approved" priority="should">
        <statement>
          The published AGENTS.md template SHALL teach the five-stage development
          process (REQ-DESIGN-PROCESS) and SHALL direct agents to the rqml CLI —
          check, status, and the loop operations — as the primary validation and
          traceability workflow, rather than ad hoc schema validation.
        </statement>
        <rationale>
          The template predates the toolchain and still prescribes raw xmllint
          against a network URL; agents follow what the marker file says, so
          the process is only as enforced as the template is current.
        </rationale>
      </req>
      <req id="REQ-AGENTS-TEMPLATE-ELICITATION" type="PR" title="Template names the activity and the sign that calls for an element" status="draft" priority="should">
        <statement>
          The published AGENTS.md template SHALL name, for each stage of the
          five-stage process, the requirements-engineering activities it carries,
          and SHALL give concrete triggers for reaching beyond the requirement and
          trace elements — the observable sign in the writing that calls for a
          business rule, a glossary term, a state machine, a goal conflict, or a
          misuse case — stated as conditional triggers rather than as a section
          checklist. It SHALL state that analysis raises no finding, so that an
          agent does not infer from a passing check that the activity was done.
        </statement>
        <rationale>
          Element families that have a CLI writer and a gate read-back are used
          heavily by agents; those without are replaced by prose in notes and
          rationale, where check, matrix and impact cannot see it. The template's
          previous instruction to use as much of the tagset as necessary supplied
          no occasion for reaching, and the guidance an agent reads at the moment
          of writing is the cheapest place to supply one. Framing the triggers
          conditionally keeps the template from manufacturing ceremonial sections
          in projects whose problem never raises them.
        </rationale>
        <acceptance>
          <criterion id="CRIT-AGENTS-TEMPLATE-ELICITATION">
            <given>The published AGENTS.md template</given>
            <when>Its workflow and schema guidance are reviewed</when>
            <then>Each stage names its requirements-engineering activities, the element triggers are stated as signs to watch for rather than sections to fill, and the absence of any analysis finding is stated.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-AGENTS-TEMPLATE-VOCABULARY" type="PR" title="Template reports findings by the artifact they name" status="draft" priority="should">
        <statement>
          The published AGENTS.md template SHALL instruct agents to report each
          finding by the artifact it identifies — the goal no requirement
          satisfies, the requirement with no verification edge, the linked file
          that changed after its edge was recorded — rather than by the state of
          the gate, and SHALL distinguish the document validation that rqml
          validate performs from requirements validation in the ISO/IEC/IEEE
          29148 sense, which a person records by approving a requirement.
        </statement>
        <rationale>
          The engine already names the missing artifact in every finding message;
          the gate-colour vocabulary agents adopt is learned from the framing text
          layered on top of it, and naming a colour invites clearing the signal
          where naming an artifact directs the next action. The validation
          distinction must be explicit because the rqml validate command name
          collides with the standard's sense of the word, and an agent that
          reports requirements as validated on a passing check claims an assurance
          no command in the toolchain performs.
        </rationale>
        <acceptance>
          <criterion id="CRIT-AGENTS-TEMPLATE-VOCABULARY">
            <given>The published AGENTS.md template</given>
            <when>It is reviewed for the vocabulary it puts in front of an agent</when>
            <then>Findings are described by the artifact they name, drift is described as a suspect link to re-read, and document validation is distinguished from the approval that records requirements validation.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-DESIGN-PROCESS" type="PR" title="Five-stage development process" status="approved" priority="should">
        <statement>
          RQML SHALL define and document a recommended five-stage development
          process — Spec, Design, Plan, Code, Verify — in which each stage
          produces a durable, version-controlled artifact (the spec, ADRs, the
          plan, code and tests, and the trace graph respectively).
        </statement>
        <rationale>
          The earlier Elicit-Specify-Implement-Verify-Trace framing collapsed
          architecture and planning into "implement" and left design decisions
          undocumented; naming Design and Plan as explicit stages surfaces the
          two points where human judgement matters most before code is written.
        </rationale>
        <acceptance>
          <criterion id="CRIT-PROCESS-DOC">
            <given>The rqml.org documentation</given>
            <when>A reader opens the Development Process page</when>
            <then>The five stages and the artifact each produces are described.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-ADR-CONVENTION" type="PR" title="Design decisions recorded as ADRs" status="approved" priority="should">
        <statement>
          Design decisions of architectural significance SHOULD be recorded as
          Architecture Decision Records in a .rqml/adr/ directory beside the
          spec, following the canonical ADR format — numbered NNNN-slug.md files,
          immutable once accepted, superseded rather than edited. A significant
          decision MAY additionally be summarized as a &lt;decision&gt; element
          for in-spec traceability.
        </statement>
        <rationale>
          Code records what was built and the spec records what is required, but
          neither records why one design was chosen over the alternatives; ADRs
          give that rationale a durable, searchable home that agents can read.
        </rationale>
        <acceptance>
          <criterion id="CRIT-ADR-DIR">
            <given>An RQML-governed project that makes a significant design decision</given>
            <when>The decision is recorded</when>
            <then>An ADR exists in .rqml/adr/ following the canonical format and naming.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-PLAN-CONVENTION" type="PR" title="Implementation plan in .rqml/plan.md" status="approved" priority="may">
        <statement>
          A multi-stage implementation plan SHOULD be recorded at .rqml/plan.md,
          framed for coding agents — each stage naming its goal, the requirement
          ids it addresses, the files it touches, and how to verify it.
        </statement>
        <acceptance>
          <criterion id="CRIT-PLAN-FILE">
            <given>A project planning multi-stage implementation work</given>
            <when>The plan is drafted</when>
            <then>It lives at .rqml/plan.md with per-stage goals, requirement ids, and verification steps.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CI-GATE" type="PR" title="Continuous integration as the authoritative gate" status="draft" priority="should">
        <statement>
          RQML SHALL document continuous integration as the authoritative
          enforcement point of a spec-first project — the one layer that cannot
          be bypassed — and SHALL document how to gate a build on rqml check,
          covering the drift baseline the gate depends on, the strictness level
          it runs at, and the build-system configuration that makes a failing
          gate block a merge rather than merely report one.
        </statement>
        <rationale>
          Editor, agent, and pre-commit enforcement are fast but voluntary: a
          teammate without the plugin, a --no-verify commit, an unarmed hook, or
          a bot committing directly routes around all of them. CI is the only
          layer nobody can skip — yet a build that merely runs the gate still
          permits the merge until the check is marked required, and a gate whose
          baseline was never committed reports success while detecting nothing.
          Documenting the wiring without those two conditions would leave readers
          with a gate that reports and never gates.
        </rationale>
        <acceptance>
          <criterion id="CRIT-CI-DOC">
            <given>The rqml.org documentation</given>
            <when>A reader opens the CI guide</when>
            <then>It states why CI is the authoritative enforcement layer, gives a complete build configuration that runs rqml check, and explains how to make that check block a merge.</then>
          </criterion>
          <criterion id="CRIT-CI-TRIAGE">
            <given>A build failing the rqml check gate</given>
            <when>The reader consults the CI guide</when>
            <then>Each blocking finding class is mapped to the command or edit that resolves it.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-QUALITY" title="Quality attributes" ownerRef="STK-MAINTAINER">
      <description>Non-functional properties the format must uphold.</description>
      <req id="REQ-LLM-READ" type="NFR" title="LLM read reliability" status="approved" priority="must">
        <statement>
          Structure SHALL be carried by explicit paired tags and semantic element
          names, not by whitespace or position.
        </statement>
      </req>
      <req id="REQ-VALIDATABLE" type="NFR" title="Machine validatability" status="approved" priority="must">
        <statement>
          ID uniqueness, trace resolution, and state-machine references SHALL be
          enforceable purely by XSD validation.
        </statement>
      </req>
      <req id="REQ-DIFF" type="NFR" title="Clean diffs" status="approved" priority="should">
        <statement>
          Document meaning SHALL be independent of insignificant whitespace so
          documents review cleanly in pull requests.
        </statement>
      </req>
      <req id="REQ-HUMAN" type="UXR" title="Human readability" status="approved" priority="must">
        <statement>
          The format SHALL remain readable to humans, with a useful minimal
          document expressible in under 15 lines.
        </statement>
      </req>
      <req id="REQ-BACKWARD-COMPAT" type="CR" title="Backward compatibility" status="approved" priority="must">
        <statement>
          Minor version increments SHALL be additive: documents valid under an
          earlier 2.x version SHALL remain valid.
        </statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-MONOREPO" title="Reference toolchain and monorepo" ownerRef="STK-TOOLBUILDERS">
      <description>
        Structure of the rqml repository as a TypeScript workspace housing the
        reference implementation alongside the schema and documentation.
      </description>
      <req id="REQ-TS-ENGINE" type="CR" title="TypeScript implementation" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>The reference toolchain SHALL be implemented in TypeScript on Node.js.</statement>
        <rationale>One language across the engine, CLI, MCP server, and editor integration.</rationale>
      </req>
      <req id="REQ-WORKSPACE" type="CR" title="Single pnpm workspace" status="approved" priority="must">
        <statement>
          The repository SHALL be a single pnpm-managed workspace whose publishable
          packages are @rqml/core, the rqml CLI, and @rqml/mcp, alongside the
          canonical schema package and the documentation site.
        </statement>
      </req>
      <req id="REQ-PACKAGE-LAYOUT" type="DR" title="Package layout" status="approved" priority="should">
        <statement>
          Source packages SHALL reside under packages/, the documentation site in
          its own app directory, and the canonical XSDs within the schema package.
        </statement>
      </req>
      <req id="REQ-CORE-DEPS" type="NFR" title="Dependency-clean core" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL NOT declare CLI argument-parsing or MCP SDK packages as
          runtime dependencies, so editors and agent integrations can embed it
          without inheriting toolchain dependencies.
        </statement>
        <rationale>Keeps the engine embeddable; the CLI and MCP server are the dependency-heavy edges.</rationale>
      </req>
      <req id="REQ-SCHEMA-CANONICAL" type="DR" title="Single canonical schema" status="approved" priority="must">
        <statement>
          Every supported schema version SHALL have a single canonical source in
          the schema package; consumers SHALL obtain it from there rather than
          maintaining copies.
        </statement>
      </req>
      <req id="REQ-SCHEMA-URLS" type="CR" title="Stable schema URLs" status="approved" priority="must">
        <statement>
          The documentation site SHALL publish every supported schema version at
          its stable https://rqml.org/schema/rqml-&lt;version&gt;.xsd URL — the flat
          form documents carry in xsi:schemaLocation — and the AGENTS.md template
          at https://rqml.org/AGENTS.md, preserving the namespace and
          schemaLocation contract that existing documents resolve against.
        </statement>
        <rationale>Published schema URLs are an immutable contract for documents in the wild.</rationale>
      </req>
      <req id="REQ-VERSION-DECOUPLE" type="CR" title="Decoupled versioning" status="approved" priority="should">
        <statement>
          The RQML spec version SHALL be versioned independently of the npm package
          versions of the toolchain.
        </statement>
      </req>
      <req id="REQ-RELEASE-CHANGESET" type="PR" title="Package changes carry a changeset" status="approved" priority="must">
        <statement>
          Continuous integration SHALL fail a pull request that modifies a
          published package without adding a changeset. The automated release
          pull request, which consumes changesets rather than adding them, SHALL
          be exempt. A change that intentionally warrants no release SHALL be
          recorded with an empty changeset rather than by omission.
        </statement>
        <rationale>
          Publishing is changeset-driven: with no changeset the release workflow
          versions nothing and publishes nothing, yet still reports success — so
          a merged fix silently never reaches users, and the omission is
          invisible precisely because everything looks green. This has already
          happened twice: the 2.2.0 compact-edge work and the CLI
          safe-invocation fix both landed on main unreleased. A failure mode
          that presents as success must be caught mechanically, not remembered.
        </rationale>
        <acceptance>
          <criterion id="CRIT-CHANGESET-REQUIRED">
            <given>A pull request that modifies a file under packages/</given>
            <when>It adds no changeset</when>
            <then>CI fails, naming the command that resolves it.</then>
          </criterion>
          <criterion id="CRIT-CHANGESET-BOT-EXEMPT">
            <given>The automated Version Packages pull request, which removes changesets and bumps package versions</given>
            <when>CI runs</when>
            <then>The guard does not fail it.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-CORE" title="Core engine (rqml-core)" ownerRef="STK-TOOLBUILDERS">
      <description>The dependency-clean library that every other surface reuses.</description>
      <req id="REQ-CORE-PARSE" type="FR" title="Parse to typed model" status="approved" priority="must" appliesTo="core">
        <statement>@rqml/core SHALL parse an RQML document into a typed in-memory model.</statement>
      </req>
      <req id="REQ-CORE-VALIDATE" type="FR" title="Deterministic validation" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL validate a document for XML well-formedness, XSD
          validity, identifier uniqueness, and trace referential integrity,
          equivalently to the schema's own constraints and without network access.
        </statement>
      </req>
      <req id="REQ-CORE-SCHEMA-DETECT" type="FR" title="Schema-version detection" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL detect the declared schema version from the document
          namespace and validate against the matching bundled schema.
        </statement>
      </req>
      <req id="REQ-CORE-TRACE-GRAPH" type="FR" title="Traceability graph" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL construct the traceability graph from trace edges and
          expose queries for impact analysis and coverage.
        </statement>
      </req>
      <req id="REQ-CORE-COVERAGE" type="FR" title="Coverage metrics" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL compute coverage deterministically: goals without
          satisfying requirements, requirements without verification, dangling
          local references, and orphaned artifacts.
        </statement>
      </req>
      <req id="REQ-CORE-DRIFT" type="FR" title="Deterministic drift detection" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL detect spec/implementation drift by resolving the
          external locators of implements edges and reporting links whose
          referenced artifact is missing or has changed since the linked
          requirement was last approved.
        </statement>
      </req>
      <req id="REQ-CORE-API" type="IR" title="Stable typed API" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL expose a stable, typed programmatic API consumed by the
          CLI, the MCP server, and external integrations.
        </statement>
      </req>
      <req id="REQ-CORE-NO-LLM" type="CR" title="No model in the engine" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL produce its validation, coverage, and drift results
          deterministically, without invoking any language model.
        </statement>
        <rationale>Reproducibility is required for a trustworthy, auditable gate.</rationale>
      </req>
      <req id="REQ-CORE-SM-INTEGRITY" type="DR" title="State-machine integrity in code" status="approved" priority="must" appliesTo="core">
        <statement>
          Integrity checking SHALL verify state-machine references in code:
          every stateMachine initial attribute SHALL resolve to a declared
          state, every transition from and to SHALL resolve to declared states
          of the same machine, and states of type "final" SHALL NOT have
          outgoing transitions.
        </statement>
        <rationale>
          The XSD declares these constraints as keyrefs, but the toolchain does
          not rely on keyref enforcement; checkIntegrity must close the gap so
          REQ-SM-INITIAL, REQ-TRANSITION-REFS, and REQ-SM-FINAL are enforced by
          the gate rather than by nothing.
        </rationale>
        <acceptance>
          <criterion id="CRIT-SM-INTEG">
            <given>A state machine whose initial attribute names an undeclared state</given>
            <when>checkIntegrity runs</when>
            <then>A diagnostic is reported and rqml check fails validation.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-DRIFT-BASELINE" type="FR" title="Drift baselines" status="approved" priority="must" appliesTo="core cli">
        <statement>
          The toolchain SHALL record a content hash for each implements-linked
          artifact in a project-local baseline store, and drift detection SHALL
          report a linked artifact as changed when its current content no
          longer matches the recorded hash.
        </statement>
        <rationale>
          Existence checking alone catches deleted artifacts only; the changed
          state required by REQ-CORE-DRIFT needs a recorded baseline to compare
          against. A sidecar store (e.g. under the .rqml/ project folder) keeps
          the spec document itself clean and diffable.
        </rationale>
        <acceptance>
          <criterion id="CRIT-DRIFT-CHANGED">
            <given>An implements-linked artifact modified after its baseline was recorded</given>
            <when>rqml check runs</when>
            <then>The link is reported as changed and the gate exits non-zero.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-DRIFT-SCOPE" type="FR" title="Fragment scope downgrades, never replaces" status="approved" priority="should" appliesTo="core cli">
        <statement>
          Drift detection SHALL continue to compare the whole content of a
          linked artifact. Where a locator names a fragment whose media type has
          defined fragment semantics, the toolchain SHALL additionally record
          that fragment's content, and SHALL report a changed artifact whose
          named fragment is unchanged as a distinct, non-blocking outcome rather
          than as drift. It SHALL report drift whenever the fragment cannot be
          resolved, is ambiguous, or has changed, and SHALL never narrow an
          artifact whose locator names no fragment.
        </statement>
        <rationale>
          The recorded hash covers the whole file, so a version bump or an edit
          elsewhere in the file drifts an edge that claims to be about one
          symbol: four consecutive releases reddened the gate on the same three
          edges, and no re-pin in a full working session caught an unintended
          change. A gate whose red is usually noise teaches its readers — now
          mostly agents — to re-pin without reading, which converts the
          guarantee into a ritual. Narrowing the hash instead of adding to it
          was rejected: a mis-resolved span yields a stable hash over the wrong
          bytes and real drift passes silently. This layer can only downgrade an
          alarm it positively proves irrelevant, so every uncertainty leaves the
          alarm standing (ADR-0018). Scope follows the locator's own fragment,
          so a prohibition such as REQ-CORE-NO-LLM — whose evidence must include
          install scripts and every dependency channel — keeps whole-file
          evidence by construction.
        </rationale>
        <acceptance>
          <criterion id="CRIT-SCOPE-CONTEXT">
            <given>An edge whose locator names a resolvable fragment, and an edit elsewhere in that file</given>
            <when>rqml check runs at standard strictness</when>
            <then>The change is reported as context-changed and the gate still passes.</then>
          </criterion>
          <criterion id="CRIT-SCOPE-EVIDENCE">
            <given>The same edge, with an edit to the named fragment itself</given>
            <when>rqml check runs</when>
            <then>The link is reported as changed and the gate exits non-zero.</then>
          </criterion>
          <criterion id="CRIT-SCOPE-FAILSAFE">
            <given>An edge whose named fragment no longer resolves, or resolves ambiguously</given>
            <when>rqml check runs</when>
            <then>The link is reported as changed rather than passing.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-STATUS-AWARE" type="FR" title="Lifecycle-aware coverage" status="approved" priority="should" appliesTo="core">
        <statement>
          Coverage SHALL distinguish artifact lifecycle status: implementation
          coverage SHALL be reported over approved requirements, and an
          implements edge whose requirement endpoint is not approved SHALL be
          reported as a finding.
        </statement>
        <rationale>
          Only approved artifacts should drive implementation (REQ-STATUS-ENUM);
          treating draft and approved requirements identically makes a strict
          gate unusable mid-project and hides premature implementation.
        </rationale>
        <acceptance>
          <criterion id="CRIT-STATUS-IMPL">
            <given>An implements edge targeting a requirement with status draft</given>
            <when>Coverage is computed</when>
            <then>A premature-implementation finding names the edge and the requirement.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-PROJECTION" type="FR" title="Scoped document projection" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL project a document, or a caller-selected subset of
          it (by section, package, or id), into the normalized document outline
          and render that projection as deterministic markdown, so any surface
          can present a readable view of the whole spec or of named parts
          without re-deriving structure.
        </statement>
        <rationale>
          The outline and markdown serializer already exist; what is missing is
          scoping — selecting sections, packages, or ids — so an agent can show
          "the MCP requirements" rather than the entire document. Scoping SHALL
          be additive options that leave the existing whole-document output
          unchanged.
        </rationale>
        <acceptance>
          <criterion id="CRIT-PROJECTION-SCOPE">
            <given>A document and a filter naming a subset of requirement ids</given>
            <when>The projection is rendered</when>
            <then>The markdown contains exactly those requirements with their resolved trace refs and nothing outside the selection, identically on repeated runs.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-MATRIX" type="FR" title="Traceability matrix derivation" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL derive a traceability matrix — one row per
          requirement carrying its status, upstream goals, implementing
          artifacts, verifying tests, and derived verification and
          implementation coverage — deterministically from the trace graph and
          coverage report, as the single source every surface renders.
        </statement>
        <rationale>
          A matrix is a presentation of coverage plus resolved titles, both
          already computed by the engine. Deriving it once in @rqml/core keeps
          the CLI, the MCP server, and the editor from disagreeing about spec
          health (REQ-CORE-API, REQ-MCP-PARITY); re-deriving it downstream is
          the divergence this requirement forbids.
        </rationale>
        <acceptance>
          <criterion id="CRIT-MATRIX-DERIVED">
            <given>A requirement with one implements edge and no verifiedBy edge</given>
            <when>The matrix is built</when>
            <then>Its row reports the implementing artifact and an unverified verification status, matching the coverage report for the same document.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-SETSTATUS" type="FR" title="Status-transition edit" status="approved" priority="must" appliesTo="core">
        <statement>
          @rqml/core SHALL provide a status-transition edit that changes the
          lifecycle status of a named artifact in the document text in place —
          preserving comments and hand formatting, re-parsing and
          integrity-checking the result before returning it, and rejecting the
          edit if it would not parse or would introduce an integrity violation.
        </statement>
        <rationale>
          Approving a requirement today means hand-editing status="draft" to
          status="approved". Mechanizing it mirrors the link operation
          (REQ-LOOP-LINK) and is the deterministic primitive the review/accept
          workflow records its decision through; the textual edit keeps the
          document diffable (QGOAL-DIFF).
        </rationale>
        <acceptance>
          <criterion id="CRIT-SETSTATUS-INPLACE">
            <given>A valid spec and a draft requirement id</given>
            <when>The status is transitioned to approved</when>
            <then>Only that requirement's status attribute changes, the document revalidates, and all other content is byte-identical.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-APPROVAL-VERDICT" type="FR" title="Non-approved-implementation verdict" status="approved" priority="should" appliesTo="core">
        <statement>
          @rqml/core SHALL expose a deterministic verdict that identifies
          implementation linked to requirements that are not approved — given
          the spec and, optionally, a set of changed artifact paths — so
          external control loops can decide whether implementation may proceed
          without a language model in the verdict path.
        </statement>
        <rationale>
          REQ-CORE-STATUS-AWARE already flags an implements edge whose
          requirement is not approved; exposing that judgement as a reusable
          predicate lets editor and agent hooks and CI gate on one engine
          result (REQ-ENFORCE-DETERMINISM), and lets the check gate later
          subsume it (ISS-PROCESS-GATE) without a rewrite.
        </rationale>
        <acceptance>
          <criterion id="CRIT-VERDICT-NONAPPROVED">
            <given>An implements edge whose target requirement has status review</given>
            <when>The verdict runs</when>
            <then>It reports that requirement and edge as not-yet-approved, identically on every run.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-SPEC-DISCOVERY" type="FR" title="Nearest-wins spec discovery" status="approved" priority="should" appliesTo="core">
        <statement>
          A spec governs the directory it is placed in and every subdirectory
          beneath it, except any subtree taken over by a nested spec, and never a
          parent directory. @rqml/core SHALL resolve the spec governing any path as
          the spec in its nearest enclosing directory — the path's own directory,
          else the closest ancestor that holds one — preferring requirements.rqml,
          else the sole *.rqml in that directory, without crossing a repository or
          workspace boundary, and SHALL enumerate every such spec beneath a root.
        </statement>
        <rationale>
          ADR-0012: one independent spec per project unit, nearest-wins, no
          umbrella. Lifting discovery into @rqml/core gives the CLI, the MCP
          server, the skill, and the VS Code extension one shared resolver
          instead of the three divergent rules they implement today.
        </rationale>
        <acceptance>
          <criterion id="CRIT-DISCOVERY-NEAREST">
            <given>A repository with specs at both a package directory and an ancestor directory</given>
            <when>Discovery resolves the spec for a file under the package</when>
            <then>The nearer package spec is returned, not the ancestor.</then>
          </criterion>
          <criterion id="CRIT-DISCOVERY-SUBTREE">
            <given>A spec at directory D and a file in a subdirectory of D with no nearer spec</given>
            <when>Discovery resolves the file's governing spec</when>
            <then>D's spec governs it, and a file in a parent of D does not resolve to D's spec.</then>
          </criterion>
          <criterion id="CRIT-DISCOVERY-AMBIGUOUS">
            <given>A directory with multiple *.rqml files and no requirements.rqml</given>
            <when>Discovery resolves that directory</when>
            <then>It reports the directory as ambiguous rather than guessing a spec.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-LINT" type="FR" title="Semantic lint checks" status="draft" priority="should" appliesTo="core">
        <statement>
          @rqml/core SHALL apply semantic lint checks beyond schema validity —
          statement quality, missing acceptance criteria, orphaned artifacts, and
          trace-coverage gaps — and report them as structured diagnostics.
        </statement>
        <rationale>
          The lint pass already ships (packages/core/src/lint) but had no
          requirement of its own — its only home was the process-level
          REQ-STRICTNESS. This captures the engine capability so it is no longer
          a ghost feature (root ADR-0004 §2).
        </rationale>
        <acceptance>
          <criterion id="CRIT-LINT-DIAG">
            <given>A requirement with no acceptance criteria</given>
            <when>The lint pass runs</when>
            <then>A structured diagnostic identifies the requirement and the missing criteria.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-ADR-REFS" type="FR" title="ADR references resolve" status="approved" priority="should" appliesTo="core cli">
        <statement>
          The lint SHALL report an Architecture Decision Record whose declared
          references — the Decision ID and Related requirements header fields —
          name an identifier that the governing spec does not declare. It SHALL
          NOT report a record whose status is superseded or rejected, an
          identifier immediately followed by a parenthetical qualifier, or an
          identifier appearing only inside such a qualifier. Free prose and
          fenced examples in the record body SHALL NOT be inspected.
        </statement>
        <rationale>
          Referential integrity covers trace edges, so a renamed or retired
          requirement silently falsifies every ADR that argues about it: the
          rationale survives while its subject disappears. An audit across the
          ecosystem found exactly two such references — both in still-accepted
          records — against 28 citations that were correct. The exclusions are
          therefore load-bearing, not conveniences: superseded records
          deliberately preserve retired ids as accurate history, a
          parenthetical marks a reference the author has qualified as living
          elsewhere (REQ-HOOK-PREIMPL (rqml-claude, rqml-codex)), and body
          prose carries historical citations and illustrative examples. A rule
          without them reports thirty findings, none actionable, and is
          switched off within a day.
        </rationale>
        <acceptance>
          <criterion id="CRIT-ADR-REF-DANGLING">
            <given>An accepted ADR whose Related requirements field names an id the spec does not declare</given>
            <when>The lint runs</when>
            <then>A finding identifies the record, the field, and the unresolved id.</then>
          </criterion>
          <criterion id="CRIT-ADR-REF-EXCLUSIONS">
            <given>A superseded ADR citing retired ids, and an accepted ADR citing a parenthetically qualified cross-document id</given>
            <when>The lint runs</when>
            <then>Neither produces a finding.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-STRICTNESS" type="FR" title="Strictness-scaled severity in the engine" status="draft" priority="should" appliesTo="core">
        <statement>
          @rqml/core SHALL implement the four strictness levels — relaxed,
          standard, strict, certified — and scale the severity of lint and
          coverage findings by the configured level, deterministically.
        </statement>
        <rationale>
          The engine realization of the process-level REQ-STRICTNESS /
          REQ-ENFORCE-STRICTNESS: scaleSeverity (packages/core/src/lint) is the
          single place levels are applied, shared by every surface. Recorded so
          the shipped capability has a core-engine requirement (root ADR-0004 §2).
        </rationale>
        <acceptance>
          <criterion id="CRIT-STRICTNESS-SCALE">
            <given>A lint finding that is a warning under standard strictness</given>
            <when>The same document is checked under certified strictness</when>
            <then>The finding is escalated to a blocking error, identically on every run.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CORE-COMPACT-PARITY" type="DR" title="Compact-form parse/integrity parity" status="approved" priority="must" appliesTo="core">
        <statement>
          The engine SHALL parse the 2.2.0 compact edge form into the same
          TraceEdge model as the equivalent 2.1.0 nested form, SHALL enforce
          referential integrity over every accepted edge form such that the
          edges visible to the parser and the references visible to the
          integrity checker are always the same set, SHALL reject an rqml:
          endpoint whose fragment does not carry a valid target id rather than
          treat it as external, and SHALL emit edges in the one canonical
          attribute order with confidence rendered as a plain decimal.
        </statement>
        <rationale>
          The integrity checker is an independent second reader of the raw XML;
          an edge form it does not know silently escapes duplicate-id and
          dangling-reference enforcement — the worst failure available to a
          deterministic-enforcement tool. Parity is therefore a requirement,
          not an implementation detail (RFC-0003). Plain-decimal confidence:
          ConfidenceType is xs:decimal, which rejects exponential notation.
        </rationale>
        <acceptance>
          <criterion id="CRIT-PARITY-FORMS">
            <given>Equivalent documents in 2.1.0 nested and 2.2.0 compact form, each containing a dangling local endpoint and a duplicate id</given>
            <when>Both are parsed and integrity-checked</when>
            <then>Both parses yield the same TraceEdge model and both checks report the same violations.</then>
          </criterion>
          <criterion id="CRIT-PARITY-DOCREF">
            <given>A compact edge whose endpoint is an rqml: URI without a valid id fragment</given>
            <when>The document is checked</when>
            <then>The checker reports an invalid doc locator; the endpoint is not treated as external.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-CLI" title="Command-line interface (rqml)" ownerRef="STK-TOOLBUILDERS">
      <description>The rqml binary: the universal substrate every integration invokes.</description>
      <req id="REQ-CLI-BINARY" type="FR" title="rqml executable" status="approved" priority="must" appliesTo="cli">
        <statement>
          The toolchain SHALL provide an rqml executable that operates
          non-interactively on a project's RQML document(s).
        </statement>
      </req>
      <req id="REQ-CLI-COMMANDS" type="FR" title="Core commands" status="approved" priority="must" appliesTo="cli">
        <statement>
          rqml SHALL provide at least: init (scaffold a spec and project marker),
          validate (schema and integrity), status (current spec and coverage
          state), and check (the enforcement gate).
        </statement>
      </req>
      <req id="REQ-CLI-INIT-MERGE" type="FR" title="init merges into an existing AGENTS.md" status="approved" priority="should" appliesTo="cli">
        <statement>
          rqml init SHALL write the RQML guidance into AGENTS.md as a managed,
          marker-delimited block: creating the file when it is absent, and
          otherwise merging the block into the existing file without altering any
          content outside the markers. Re-running init SHALL refresh the block in
          place idempotently and SHALL preserve any strictness level the project
          already declares.
        </statement>
        <rationale>
          ADR-0016. AGENTS.md is the agent's native instruction file (notably for
          Codex), so a project adopting RQML usually already has one. The earlier
          create-or-skip behavior silently left such projects without the process
          contract. A managed block adopts cleanly alongside existing guidance and
          stays refreshable as the template (REQ-AGENTS-TEMPLATE) evolves.
        </rationale>
        <acceptance>
          <criterion id="CRIT-INIT-MERGE">
            <given>A project whose AGENTS.md already holds hand-written guidance</given>
            <when>rqml init is run</when>
            <then>The existing guidance is preserved and an RQML block is appended between BEGIN/END markers.</then>
          </criterion>
          <criterion id="CRIT-INIT-IDEMPOTENT">
            <given>An AGENTS.md that already contains a current RQML block</given>
            <when>rqml init is run again</when>
            <then>The file is left unchanged and the block is not duplicated.</then>
          </criterion>
          <criterion id="CRIT-INIT-STRICTNESS">
            <given>An AGENTS.md whose RQML block declares a non-default strictness</given>
            <when>rqml init refreshes the block</when>
            <then>The declared strictness is retained rather than reset to standard.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CLI-CHECK-GATE" type="FR" title="Check gate" status="approved" priority="must" appliesTo="cli">
        <statement>
          rqml check SHALL act as a deterministic gate, exiting zero only when the
          document is valid and no blocking drift or coverage violation exists, and
          non-zero otherwise.
        </statement>
        <acceptance>
          <criterion id="CRIT-GATE-FAIL">
            <given>A project whose implementation has drifted from the spec</given>
            <when>rqml check is run</when>
            <then>It exits non-zero and reports the drift.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CLI-JSON" type="IR" title="Machine-readable output" status="approved" priority="must" appliesTo="cli">
        <statement>
          rqml status and rqml check SHALL emit a documented, stable JSON
          representation for control loops, in addition to human-readable output.
        </statement>
      </req>
      <req id="REQ-CLI-EXIT-CODES" type="IR" title="Stable exit codes" status="approved" priority="must" appliesTo="cli">
        <statement>
          rqml SHALL use documented, stable exit codes distinguishing success,
          validation failure, drift or coverage failure, and usage error.
        </statement>
      </req>
      <req id="REQ-CLI-SAFE-INVOCATION" type="IR" title="Help and unrecognized input never mutate" status="approved" priority="must" appliesTo="cli">
        <statement>
          rqml SHALL treat -h and --help as a help request for every command,
          printing usage and exiting successfully without reading or writing any
          project file. A command that modifies files SHALL additionally reject
          unrecognized flags rather than proceeding, so that a mistyped or
          unsupported option can never cause a write.
        </statement>
        <rationale>
          `rqml migrate --help` silently migrated the discovered spec in place:
          help was only handled in the command position, and migrate takes no
          required positional, so the flag fell through to spec discovery and a
          write. Commands that require positionals (link, approve) were spared
          only by accident. A mutating command must never act on input it does
          not understand — the spec is the user's source of truth, and a
          surprise rewrite of it is the worst failure this CLI can produce.
        </rationale>
        <acceptance>
          <criterion id="CRIT-CLI-HELP-NOWRITE">
            <given>A project whose spec a command would otherwise modify</given>
            <when>That command is invoked with --help or -h</when>
            <then>Usage is printed, the exit status is success, and the spec is byte-identical.</then>
          </criterion>
          <criterion id="CRIT-CLI-UNKNOWN-FLAG">
            <given>A project whose spec a mutating command would otherwise modify</given>
            <when>That command is invoked with an unrecognized flag</when>
            <then>It exits with the usage status and the spec is byte-identical.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CLI-OFFLINE" type="NFR" title="Offline operation" status="approved" priority="must" appliesTo="cli">
        <statement>rqml SHALL run fully offline, bundling the schema via @rqml/core.</statement>
      </req>
      <req id="REQ-CLI-SPEED" type="NFR" title="Interactive latency" status="approved" priority="should" appliesTo="cli">
        <statement>
          rqml check and rqml status SHALL complete quickly enough to run on every
          editor save or agent turn, targeting under ~1s on a typical project.
        </statement>
      </req>
      <req id="REQ-WORKSPACE-FANOUT" type="FR" title="Workspace-wide check" status="approved" priority="should" appliesTo="cli">
        <statement>
          rqml SHALL offer a workspace mode that runs validate, status, and check
          across every unit spec discovered beneath a repository root and returns
          a single aggregated exit code — non-zero if any unit fails.
        </statement>
        <rationale>
          ADR-0012: monorepo CI needs one "is the whole repo green?" answer rather
          than N separate invocations. Built on REQ-CORE-SPEC-DISCOVERY.
        </rationale>
        <acceptance>
          <criterion id="CRIT-FANOUT-EXIT">
            <given>A repository with multiple unit specs, one of which fails its check</given>
            <when>rqml check is run in workspace mode</when>
            <then>It checks every unit spec and exits non-zero, naming the failing unit.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-CLI-LINT" type="FR" title="Lint command" status="approved" priority="should" appliesTo="cli">
        <statement>
          rqml SHALL provide a lint command that runs the engine's semantic lint
          over the resolved spec and reports the findings, scaling their severity
          by the configured strictness, and exiting non-zero when any finding is
          an error.
        </statement>
        <rationale>
          @rqml/core's lint was only reachable through status and check; a focused
          command surfaces document-quality findings directly for authors and CI.
        </rationale>
        <acceptance>
          <criterion id="CRIT-LINT-STRICT">
            <given>A requirement with no acceptance criteria</given>
            <when>rqml lint --strictness strict is run</when>
            <then>It reports a missing-acceptance error and exits non-zero.</then>
          </criterion>
          <criterion id="CRIT-LINT-CLEAN">
            <given>A spec whose requirements all carry acceptance criteria</given>
            <when>rqml lint is run</when>
            <then>It reports no findings and exits zero.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-MCP" title="MCP server (rqml-mcp)" ownerRef="STK-TOOLBUILDERS">
      <description>The agent-facing surface exposing core capabilities as MCP tools.</description>
      <req id="REQ-MCP-SERVER" type="FR" title="MCP server" status="approved" priority="must" appliesTo="mcp">
        <statement>
          The toolchain SHALL provide an MCP server exposing RQML capabilities as
          tools to coding agents.
        </statement>
      </req>
      <req id="REQ-MCP-TOOLS" type="FR" title="Exposed tools" status="approved" priority="must" appliesTo="mcp">
        <statement>
          The MCP server SHALL expose at least validate, status, check, trace
          query, and skeleton-generation tools, each backed by @rqml/core.
        </statement>
      </req>
      <req id="REQ-MCP-PARITY" type="CR" title="CLI and MCP parity" status="approved" priority="must" appliesTo="mcp">
        <statement>
          For the same input, an MCP tool SHALL return results equivalent to the
          corresponding rqml CLI command, since both are backed by one engine.
        </statement>
      </req>
      <req id="REQ-MCP-READONLY" type="SR" title="No silent side effects" status="approved" priority="should" appliesTo="mcp">
        <statement>
          The MCP server SHALL treat the spec as read-mostly and SHALL NOT perform
          irreversible filesystem actions without explicit caller intent.
        </statement>
      </req>
      <req id="REQ-MCP-PATH-INPUT" type="IR" title="Path inputs" status="approved" priority="must" appliesTo="mcp">
        <statement>
          Every MCP tool SHALL accept a filesystem path to the spec document as
          an alternative to inline document text, reading the file without
          modifying it.
        </statement>
        <rationale>
          Requiring agents to inline a multi-thousand-line document into every
          tool call wastes context and discourages use; reading by path keeps
          the loop cheap.
        </rationale>
        <acceptance>
          <criterion id="CRIT-MCP-PATH">
            <given>A tool call providing a path argument and no inline document</given>
            <when>The tool executes</when>
            <then>The result equals the result for the same document passed inline.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-MCP-INTERACTION-BOUNDARY" type="CR" title="Data plane, not interaction surface" status="approved" priority="must" appliesTo="mcp">
        <statement>
          The MCP server SHALL expose RQML capabilities as text and JSON tool
          results and SHALL NOT depend on optional MCP client features —
          resources, prompts, elicitation, or sampling — for any core workflow,
          so every capability remains reachable on hosts that implement tools
          alone and stays at parity with the CLI.
        </statement>
        <rationale>
          Resources and elicitation have no CLI equivalent and uneven client
          support; making a workflow such as accepting a requirement depend on
          them would break CLI/MCP parity (REQ-MCP-PARITY) and fail silently on
          hosts that lack them. Human interaction belongs to the host
          integration, not the data plane.
        </rationale>
        <acceptance>
          <criterion id="CRIT-MCP-TOOLS-ONLY">
            <given>A host that supports MCP tools but not resources or elicitation</given>
            <when>Any RQML capability is invoked</when>
            <then>It succeeds and returns the same result the corresponding CLI command would.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-LOOP" title="Agent workflow operations" ownerRef="STK-TEAMS">
      <description>
        Deterministic spec operations serving the middle of the agent loop —
        choosing work, reading one artifact, and recording trace links — so the
        toolchain supports the Code and Verify stages of the five-stage
        Spec-Design-Plan-Code-Verify process (REQ-DESIGN-PROCESS), not only
        validation at the start and the gate at the end. Generation of
        target-language code or tests is intentionally excluded
        (DEC-DETERMINISTIC-CHECK: the model proposes, the toolchain disposes).
      </description>
      <req id="REQ-LOOP-LINK" type="FR" title="Link recording" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL provide a link operation, on both the CLI and MCP
          surfaces, that appends a schema-valid trace edge of any trace type to
          the spec document given two endpoints, each a declared artifact id or
          an external locator URI, at least one of them local. The operation
          SHALL orient implements edges external-to-local and verifiedBy edges
          local-to-external regardless of argument order, record other types
          exactly as given, reject a bare undeclared token rather than treat it
          as an external locator, stamp new edges status="draft" with a
          createdBy identity unless the caller overrides them, accept optional
          notes, confidence, and tags, and record the drift baseline for the
          linked artifact where one applies.
        </statement>
        <rationale>
          Hand-editing XML trace edges is the highest-friction step of the loop
          and the one agents skip; recording links must be mechanical for every
          trace type — satisfies and refines edges are appended continuously in
          agent-driven authoring — for the drift and coverage story to hold.
          Draft/createdBy stamping gives the trace log the provenance its
          review-and-approve curation depends on, while notes, confidence, and
          tags make judgment-bearing markup one flag away instead of a hand
          edit (ADR-0017). The write is explicit caller intent, consistent
          with REQ-MCP-READONLY.
        </rationale>
        <acceptance>
          <criterion id="CRIT-LINK-ROUNDTRIP">
            <given>A valid spec, a requirement id, and an existing source path</given>
            <when>The link operation runs</when>
            <then>The document revalidates and coverage counts the requirement as implemented.</then>
          </criterion>
          <criterion id="CRIT-LINK-LOCAL">
            <given>A valid spec declaring a requirement and a goal</given>
            <when>The link operation runs with the two ids and type satisfies</when>
            <then>A satisfies edge from the requirement to the goal is appended, the document revalidates, and coverage counts the goal as covered.</then>
          </criterion>
          <criterion id="CRIT-LINK-PROVENANCE">
            <given>A valid spec and any append-mode link request without status or createdBy overrides</given>
            <when>The link operation appends the edge</when>
            <then>The recorded edge carries status="draft" and a non-empty createdBy identity.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-RELINK" type="FR" title="Link maintenance" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The link operation SHALL also maintain existing trace edges. In
          update mode, given an artifact id and a new external locator URI, it
          SHALL replace the external locator of the existing implements or
          verifiedBy edge — matched by an explicit edge id or by the same id
          derivation used when appending — and refresh the edge's drift
          baseline entry. In refresh mode, given an edge id alone, it SHALL
          re-record the drift baseline for the edge's current artifact content
          without modifying the spec document or re-stating the URI.
        </statement>
        <rationale>
          Repointing an edge at a new artifact, or blessing an intentional
          change to a linked artifact, otherwise forces hand edits of the
          trace XML and the baseline store — exactly the manual editing
          REQ-LOOP-LINK exists to eliminate. Both modes stay edge-scoped:
          re-hashing every link at once would silently bless unrelated drift.
        </rationale>
        <acceptance>
          <criterion id="CRIT-RELINK-UPDATE">
            <given>A spec with an implements edge recorded by the link operation and its baseline entry</given>
            <when>Update mode runs with the same artifact id and a different existing target URI</when>
            <then>The edge's external locator holds the new URI, no duplicate edge is created, the document revalidates, and the baseline entry matches the new artifact's content.</then>
          </criterion>
          <criterion id="CRIT-RELINK-REFRESH">
            <given>A linked artifact intentionally modified after its baseline was recorded</given>
            <when>Refresh mode runs with the edge id</when>
            <then>The spec document is byte-identical and a subsequent check reports no drift for that edge.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-MIGRATE" type="FR" title="Document migration" status="approved" priority="must" appliesTo="core cli">
        <statement>
          The toolchain SHALL provide a migrate operation that rewrites a 2.0.1
          or 2.1.0 document to the current schema version by updating the root
          version and namespace and re-emitting each trace edge in the
          canonical compact form, leaving every byte outside the root element
          tag and the rewritten edges unchanged — including bytes inside XML
          comments, which SHALL never absorb an edge rewrite — and leaving the
          recorded drift baseline untouched, so the document's drift state
          before and after migration is identical.
        </statement>
        <rationale>
          The 2.2.0 serialization change (RFC-0003) is breaking; migration must
          be a mechanical, reviewable sweep. Byte-minimality keeps the diff to
          exactly "the trace section got shorter" (QGOAL-DIFF). Baselines hash
          linked-artifact content keyed by edge id, and migration changes
          neither — so no re-baselining is needed for a clean repo, and
          re-recording would silently bless any drift that already existed,
          the one thing a deterministic-enforcement tool must never do.
        </rationale>
        <acceptance>
          <criterion id="CRIT-MIGRATE-ROUNDTRIP">
            <given>A valid 2.1.0 document with local, external, and doc edges, comments, and hand formatting</given>
            <when>The migrate operation runs</when>
            <then>The result validates against the 2.2.0 schema, parses to the identical TraceEdge model, and differs from the source only in the root element tag and the trace edges.</then>
          </criterion>
          <criterion id="CRIT-MIGRATE-BASELINE">
            <given>A 2.1.0 document with implements edges and a recorded drift baseline, one linked artifact of which has drifted</given>
            <when>The migrate operation runs via the CLI</when>
            <then>A subsequent check reports exactly the drift it reported before migration: the undrifted edges stay clean and the drifted edge still fails.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-SHOW" type="FR" title="Artifact extraction" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL extract a single artifact by id — its statement,
          acceptance criteria, and resolved trace neighborhood — as JSON and as
          markdown, so an agent can work from a relevant slice of the spec
          without loading the whole document.
        </statement>
        <acceptance>
          <criterion id="CRIT-SHOW-SLICE">
            <given>A spec containing a requirement with acceptance criteria and trace edges</given>
            <when>The artifact is extracted by id</when>
            <then>The output contains the statement, the criteria, and every edge touching the id, and nothing else.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-IMPACT" type="FR" title="Impact query" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL answer impact queries: given an artifact id, it
          SHALL traverse the trace graph transitively in both directions and
          return the affected artifacts grouped by edge type and direction.
        </statement>
        <rationale>
          "What breaks if this changes?" is the question an engineering agent
          must ask before touching anything (SCN-IMPACT); REQ-CORE-TRACE-GRAPH
          promises the query and coverage alone does not answer it.
        </rationale>
        <acceptance>
          <criterion id="CRIT-IMPACT-TRANSITIVE">
            <given>A goal satisfied by a requirement that is verified by a test</given>
            <when>Impact is queried for the goal</when>
            <then>Both the requirement and the test are reported with their edge paths.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-SKELETON" type="FR" title="Skeleton generation" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL generate schema-valid RQML snippets — at least
          req, trace edge, testCase, and stateMachine skeletons — so authoring
          tools and agents never emit structurally invalid XML.
        </statement>
        <notes>
          Realizes the skeleton-generation tool already required of the MCP
          server by REQ-MCP-TOOLS. Scope is RQML snippets only: target-language
          code and test generation are excluded by design.
        </notes>
        <acceptance>
          <criterion id="CRIT-SKELETON-VALID">
            <given>A skeleton request for any supported element kind</given>
            <when>The snippet is inserted into a valid document</when>
            <then>The document still validates against the XSD.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-OVERVIEW" type="FR" title="Spec overview" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL provide an overview operation, on both the CLI and
          MCP surfaces, that renders the spec — whole, or scoped to named
          sections, packages, or ids — as markdown and as JSON, backed by the
          core projection, so an agent or human can read an orienting view of
          the requirements without opening the raw document.
        </statement>
        <rationale>
          rqml status gives metrics and rqml show gives one artifact, but
          nothing renders a readable overview of the spec or a chosen part of
          it (QGOAL-HUMAN, GOAL-LLM-CONTEXT). Both surfaces SHALL return
          equivalent results for the same input (REQ-MCP-PARITY).
        </rationale>
        <acceptance>
          <criterion id="CRIT-OVERVIEW-PARITY">
            <given>A spec and a section selection</given>
            <when>Overview is requested on the CLI and via the MCP tool</when>
            <then>Both return the same projection content.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-MATRIX" type="FR" title="Traceability matrix view" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL provide a traceability-matrix operation, on both
          the CLI and MCP surfaces, that renders the core matrix as a text table
          and as JSON, with optional filtering by status, type, or coverage gap,
          so an agent or human can review requirement-to-implementation-to-test
          coverage in one view.
        </statement>
        <rationale>
          The matrix is the spec-health surface the VS Code extension already
          offers; agents have no text equivalent (GOAL-TRACEABILITY,
          QGOAL-HUMAN). Derivation is REQ-CORE-MATRIX; this requirement is its
          CLI and MCP exposure, returning equivalent results on both
          (REQ-MCP-PARITY).
        </rationale>
        <acceptance>
          <criterion id="CRIT-MATRIX-SURFACE">
            <given>A spec with mixed coverage</given>
            <when>The matrix operation runs with a filter for unverified requirements</when>
            <then>The output lists exactly the requirements lacking a verifiedBy edge.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-LOOP-APPROVE" type="FR" title="Requirement approval" status="approved" priority="must" appliesTo="core cli mcp">
        <statement>
          The toolchain SHALL provide an approve operation, on both the CLI and
          MCP surfaces, that transitions a named requirement's lifecycle status
          — backed by the core status-transition edit — recording the change as
          an explicit, intent-bearing write consistent with the MCP read-mostly
          contract.
        </statement>
        <rationale>
          Once requirements can be reviewed in an overview and a matrix,
          accepting them must be a mechanical, auditable step rather than a hand
          edit (GOAL-PRIMARY-ARTIFACT, GOAL-ENFORCEMENT). The write is explicit
          caller intent, like REQ-LOOP-LINK, consistent with REQ-MCP-READONLY.
        </rationale>
        <acceptance>
          <criterion id="CRIT-APPROVE-WRITE">
            <given>A draft requirement</given>
            <when>Approve is invoked with explicit intent</when>
            <then>The requirement's status becomes approved, the document revalidates, and no other content changes.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

    <reqPackage id="PKG-ENFORCEMENT" title="Spec-first enforcement" ownerRef="STK-TEAMS">
      <description>
        The deterministic primitives the toolchain provides so external control
        loops (editor hooks, agent hooks, CI) can enforce spec-first development.
        The agent-specific harness is specified in downstream integration repos.
      </description>
      <req id="REQ-ENFORCE-PRIMITIVES" type="PR" title="Enforcement primitives" status="approved" priority="must">
        <statement>
          The toolchain SHALL provide the deterministic primitives required to
          enforce spec-first development externally — a check gate, a status
          surface, and drift detection — so enforcement does not rely on voluntary
          model compliance.
        </statement>
      </req>
      <req id="REQ-ENFORCE-DETERMINISM" type="PR" title="Reproducible enforcement" status="approved" priority="must">
        <statement>
          Enforcement decisions SHALL be reproducible: the same document and
          codebase SHALL yield the same check verdict on every run and machine.
        </statement>
      </req>
      <req id="REQ-ENFORCE-AUTHOR-SPLIT" type="PR" title="Authoring vs. enforcement" status="approved" priority="should">
        <statement>
          Language-model assistance SHALL be confined to authoring and proposing
          RQML content; it SHALL NOT be a required participant in the enforcement
          gate.
        </statement>
      </req>
      <req id="REQ-ENFORCE-CODE-TRACE" type="PR" title="Explicit code traceability" status="approved" priority="should">
        <statement>
          Implementation artifacts SHALL be linked to the requirements they realize
          via implements trace edges using external locators, so drift can be
          detected deterministically.
        </statement>
      </req>
      <req id="REQ-ENFORCE-CERTIFIED" type="PR" title="Certified audit trail" status="approved" priority="should">
        <statement>
          Under the certified strictness level, the toolchain SHALL record an
          append-only audit trail of enforcement checks suitable as compliance
          evidence.
        </statement>
        <notes>Supports regulated domains such as IEC 62304 and ISO 26262.</notes>
      </req>
      <req id="REQ-ENFORCE-STRICTNESS" type="PR" title="Strictness-governed enforcement" status="approved" priority="should">
        <statement>
          Enforcement intensity SHALL be governed by the configured strictness
          level (relaxed, standard, strict, certified).
        </statement>
      </req>
      <req id="REQ-ENFORCE-APPROVAL-GATE" type="PR" title="Approval-before-implementation gate" status="approved" priority="should">
        <statement>
          The toolchain SHALL provide a deterministic approval-gate primitive —
          the non-approved-implementation verdict — so external control loops
          (editor hooks, agent hooks, CI) can block implementation of
          requirements that are not yet approved, without a language model in
          the verdict path.
        </statement>
        <rationale>
          Spec-first means only approved requirements drive implementation
          (REQ-STATUS-ENUM), yet today nothing blocks code written against a
          draft requirement until the end-of-session check. Exposing the
          verdict as a primitive lets enforcement happen at the moment of the
          change; whether the standard check gate itself adopts it is deferred
          to ISS-PROCESS-GATE.
        </rationale>
        <acceptance>
          <criterion id="CRIT-GATE-PRIMITIVE">
            <given>A change implementing a requirement that is not approved</given>
            <when>The approval-gate primitive is consulted</when>
            <then>It returns a blocking verdict naming the requirement, reproducibly.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-APPROVAL-PROVENANCE" type="DR" title="Approval provenance under certified" status="draft" priority="should">
        <statement>
          Under the certified strictness level, the spec SHALL be able to record
          approval provenance — the approver identity and the approval timestamp
          — for an approved artifact, through optional, backward-compatible
          metadata that documents valid under earlier 2.x schemas continue to
          satisfy.
        </statement>
        <rationale>
          The current approval model is role-based with no individual approver
          or timestamp, so an accepted requirement carries no durable record of
          who accepted it or when — insufficient as audit-grade evidence for
          regulated domains (REQ-ENFORCE-CERTIFIED). The metadata SHALL be
          optional and additive so lightweight projects are unaffected
          (REQ-BACKWARD-COMPAT).
        </rationale>
        <acceptance>
          <criterion id="CRIT-PROVENANCE-OPTIONAL">
            <given>A minimal spec with no provenance metadata</given>
            <when>It is validated under standard strictness</when>
            <then>It remains valid; and under certified strictness, an approved artifact missing provenance yields a finding requesting it.</then>
          </criterion>
        </acceptance>
      </req>
    </reqPackage>

  </requirements>

  <!-- ============================================================= -->
  <!-- BEHAVIOR — the lifecycle of an RQML artifact's status         -->
  <!-- ============================================================= -->
  <behavior>
    <stateMachine id="SM-DOC-LIFECYCLE" name="Artifact Lifecycle" entityRef="ENT-DOC" initial="ST-DRAFT">
      <description>
        The status lifecycle shared by documents, requirements, goals, decisions,
        and trace edges. Only the approved state should drive implementation.
      </description>
      <state id="ST-DRAFT" name="Draft" type="initial">
        <description>Initial state; content is incomplete or unreviewed.</description>
        <invariant>Not yet driving implementation.</invariant>
      </state>
      <state id="ST-REVIEW" name="Review">
        <description>Under stakeholder review; awaiting feedback or approval.</description>
        <onEntry>Notify reviewers.</onEntry>
      </state>
      <state id="ST-APPROVED" name="Approved">
        <description>Formally accepted; ready for implementation.</description>
        <invariant>May be referenced by implements trace edges.</invariant>
      </state>
      <state id="ST-DEPRECATED" name="Deprecated" type="final">
        <description>No longer active; retained for historical reference.</description>
        <onEntry>Record supersedes/deprecates trace edge to any replacement.</onEntry>
      </state>
      <transition id="TR-SUBMIT" from="ST-DRAFT" to="ST-REVIEW" event="submit">
        <description>Author submits the artifact for review.</description>
        <guard>Required fields are populated.</guard>
      </transition>
      <transition id="TR-APPROVE" from="ST-REVIEW" to="ST-APPROVED" event="approve">
        <description>Reviewers accept the artifact.</description>
        <guard>All blocking issues resolved.</guard>
        <action>Record approval sign-off.</action>
      </transition>
      <transition id="TR-REVISE" from="ST-REVIEW" to="ST-DRAFT" event="revise">
        <description>Reviewers request changes, returning the artifact to draft.</description>
      </transition>
      <transition id="TR-DEPRECATE-APPROVED" from="ST-APPROVED" to="ST-DEPRECATED" event="deprecate">
        <description>An approved artifact is superseded or retired.</description>
      </transition>
      <transition id="TR-DEPRECATE-DRAFT" from="ST-DRAFT" to="ST-DEPRECATED" event="abandon">
        <description>A draft artifact is abandoned.</description>
      </transition>
    </stateMachine>
    <stateMachine id="SM-IMPL-STATUS" name="Implementation Link Lifecycle" entityRef="ENT-IMPL-LINK" initial="STIMPL-UNLINKED">
      <description>
        The lifecycle of a requirement's implementation as tracked deterministically
        by rqml check via implements edges and their external locators.
      </description>
      <state id="STIMPL-UNLINKED" name="Unlinked" type="initial">
        <description>No implements edge links the requirement to any code artifact.</description>
        <invariant>Counts against implementation coverage.</invariant>
      </state>
      <state id="STIMPL-LINKED" name="Linked">
        <description>An implements edge exists and its target artifact resolves.</description>
      </state>
      <state id="STIMPL-VERIFIED" name="Verified">
        <description>The linked artifact resolves and its associated tests pass.</description>
      </state>
      <state id="STIMPL-DRIFTED" name="Drifted">
        <description>The linked artifact is missing or has changed since the requirement was approved.</description>
        <invariant>Blocks the check gate under strict and certified levels.</invariant>
      </state>
      <transition id="TRIMPL-LINK" from="STIMPL-UNLINKED" to="STIMPL-LINKED" event="link">
        <description>An implements edge is added with a resolvable external locator.</description>
      </transition>
      <transition id="TRIMPL-VERIFY" from="STIMPL-LINKED" to="STIMPL-VERIFIED" event="verify">
        <description>Verification tests for the requirement pass.</description>
      </transition>
      <transition id="TRIMPL-DRIFT-L" from="STIMPL-LINKED" to="STIMPL-DRIFTED" event="drift">
        <description>The linked artifact goes missing or changes unexpectedly.</description>
      </transition>
      <transition id="TRIMPL-DRIFT-V" from="STIMPL-VERIFIED" to="STIMPL-DRIFTED" event="drift">
        <description>A previously verified artifact changes after approval.</description>
      </transition>
      <transition id="TRIMPL-RECONCILE" from="STIMPL-DRIFTED" to="STIMPL-LINKED" event="reconcile">
        <description>The spec or code is updated so the link resolves again.</description>
      </transition>
    </stateMachine>
  </behavior>

  <!-- ============================================================= -->
  <!-- VERIFICATION                                                  -->
  <!-- ============================================================= -->
  <verification>
    <testSuite id="TS-CONFORMANCE" title="RQML conformance suite">
      <description>
        Validates that a document conforms to the structural and referential
        rules of the schema generation it declares.
      </description>
    </testSuite>
    <testSuite id="TS-TOOLCHAIN" title="Reference toolchain suite">
      <description>
        Validates the deterministic behavior, packaging, and contracts of the core
        engine, CLI, and MCP server.
      </description>
    </testSuite>
    <testCase id="TC-XSD-VALID" type="integration" title="Valid document passes XSD">
      <purpose>Confirm a correct document validates against the schema generation it declares.</purpose>
      <steps>Validate each bundled example document against the XSD for its declared version.</steps>
      <expected>No schema violations are reported.</expected>
    </testCase>
    <testCase id="TC-UNIQUE-ID" type="unit" title="Duplicate IDs rejected">
      <purpose>Verify the allIds key constraint.</purpose>
      <steps>Validate a document containing two elements with the same id.</steps>
      <expected>Validation fails citing a duplicate key.</expected>
    </testCase>
    <testCase id="TC-TRACE-RESOLVE" type="unit" title="Dangling local trace rejected">
      <purpose>Verify trace referential integrity.</purpose>
      <steps>Validate a document whose local locator id is undeclared.</steps>
      <expected>Validation fails on traceFromRef/traceToRef.</expected>
    </testCase>
    <testCase id="TC-SM-INITIAL" type="unit" title="Unresolved initial state rejected">
      <purpose>Verify state-machine initial reference.</purpose>
      <steps>Validate a state machine whose @initial names no declared state.</steps>
      <expected>Validation fails on smInitialRef.</expected>
    </testCase>
    <testCase id="TC-MINIMAL-DOC" type="acceptance" title="Minimal document is valid">
      <purpose>Confirm RQML scales down.</purpose>
      <steps>Validate a document with only meta and one requirement.</steps>
      <expected>Validation succeeds.</expected>
    </testCase>
    <testCase id="TC-CHECK-GATE" type="acceptance" title="Check gate fails on drift">
      <purpose>Confirm rqml check gates on drift.</purpose>
      <steps>Run rqml check on a project whose code has diverged from an implements-linked requirement.</steps>
      <expected>The process exits non-zero and the report identifies the drifted link.</expected>
    </testCase>
    <testCase id="TC-CHECK-DETERMINISM" type="integration" title="Verdicts are reproducible">
      <purpose>Verify deterministic enforcement.</purpose>
      <steps>Run rqml check twice on identical inputs on two machines.</steps>
      <expected>Both runs produce the same verdict and findings.</expected>
    </testCase>
    <testCase id="TC-DRIFT-DETECT" type="unit" title="Missing target is drift">
      <purpose>Verify drift detection from implements locators.</purpose>
      <steps>Resolve an implements edge whose external locator points to a missing artifact.</steps>
      <expected>The link is reported as drifted.</expected>
    </testCase>
    <testCase id="TC-CORE-OFFLINE" type="integration" title="Validation works offline">
      <purpose>Verify offline operation with the bundled schema.</purpose>
      <steps>Validate a document with no network access.</steps>
      <expected>Validation completes using the bundled schema.</expected>
    </testCase>
    <testCase id="TC-CORE-NO-DEPS" type="inspection" title="Core has no CLI or MCP deps">
      <purpose>Verify the dependency-clean core boundary.</purpose>
      <steps>Inspect the published @rqml/core dependency tree.</steps>
      <expected>No CLI argument-parser or MCP SDK runtime dependencies are present.</expected>
    </testCase>
    <testCase id="TC-SCHEMA-URL" type="integration" title="Schema served at canonical URL">
      <purpose>Verify the published-URL contract for every supported version.</purpose>
      <steps>For each version in SCHEMA_VERSIONS, request https://rqml.org/schema/rqml-&lt;version&gt;.xsd.</steps>
      <expected>Each request returns 200 with a body byte-identical to that version's canonical file in the schema package. A version missing from the site is a failure — rqml-2.2.0.xsd returned 404 for the whole 2.2.0 release because this case had no executable form.</expected>
    </testCase>
    <testCase id="TC-MCP-PARITY" type="integration" title="MCP and CLI agree">
      <purpose>Verify single-engine parity.</purpose>
      <steps>Run the MCP check tool and rqml check on the same project.</steps>
      <expected>Both return equivalent results.</expected>
    </testCase>
    <testCase id="TC-SM-INTEGRITY" type="unit" title="Unresolved state references rejected in code">
      <purpose>Verify in-code state-machine integrity checking.</purpose>
      <steps>Run checkIntegrity on a machine with an undeclared initial state, a dangling transition endpoint, and an outgoing transition from a final state.</steps>
      <expected>Each defect yields a diagnostic.</expected>
    </testCase>
    <testCase id="TC-DRIFT-CHANGED" type="integration" title="Changed artifact is drift">
      <purpose>Verify baseline-based change detection.</purpose>
      <steps>Link an artifact, modify the file, run rqml check.</steps>
      <expected>The link is reported as changed and the gate exits non-zero.</expected>
    </testCase>
    <testCase id="TC-LINK-ROUNDTRIP" type="acceptance" title="Link operation preserves validity">
      <purpose>Verify mechanical trace recording.</purpose>
      <steps>Run the link operation for a requirement and an existing file, then revalidate and recompute coverage.</steps>
      <expected>The document validates and the requirement counts as implemented.</expected>
    </testCase>
    <testCase id="TC-RELINK-UPDATE" type="acceptance" title="Update repoints an edge in place">
      <purpose>Verify mechanical edge maintenance.</purpose>
      <steps>Link a requirement to a file, then run the link operation in update mode with a different existing file.</steps>
      <expected>The same edge points at the new URI, the document revalidates, and the baseline entry matches the new file.</expected>
    </testCase>
    <testCase id="TC-RELINK-REFRESH" type="integration" title="Refresh blesses an intentional change">
      <purpose>Verify edge-scoped baseline refresh.</purpose>
      <steps>Link a requirement to a file, modify the file so check fails on drift, then run refresh mode with the edge id.</steps>
      <expected>The spec document is unchanged and rqml check passes again.</expected>
    </testCase>
    <testCase id="TC-SHOW-SLICE" type="acceptance" title="Artifact slice is self-contained">
      <purpose>Verify single-artifact extraction.</purpose>
      <steps>Extract one requirement by id from a document with many sections.</steps>
      <expected>The slice holds the statement, criteria, and trace neighborhood only.</expected>
    </testCase>
    <testCase id="TC-IMPACT-TRANSITIVE" type="unit" title="Impact traverses transitively">
      <purpose>Verify the impact query.</purpose>
      <steps>Query impact for an artifact two edges away from a test.</steps>
      <expected>The transitive closure includes the test, grouped by edge type and direction.</expected>
    </testCase>
  </verification>

  <!-- ============================================================= -->
  <!-- TRACE                                                         -->
  <!-- ============================================================= -->
  <trace>
    <!-- Requirements satisfy goals -->
    <edge id="E-DOC-PRIMARY" type="satisfies" from="REQ-REQUIRED-SECTIONS" to="GOAL-PRIMARY-ARTIFACT" confidence="0.9"/>
    <edge id="E-XML-LLM" type="satisfies" from="REQ-XML" to="GOAL-LLM-CONTEXT" confidence="0.9"/>
    <edge id="E-TRACE-GOAL" type="satisfies" from="REQ-TRACE-EDGE" to="GOAL-TRACEABILITY" confidence="0.95"/>
    <edge id="E-STRICT-LOW" type="satisfies" from="REQ-STRICTNESS" to="GOAL-LOW-CEREMONY" confidence="0.8"/>
    <edge id="E-LLMREAD-QGOAL" type="satisfies" from="REQ-LLM-READ" to="QGOAL-LLM-READ" confidence="0.9"/>
    <edge id="E-VALID-QGOAL" type="satisfies" from="REQ-VALIDATABLE" to="QGOAL-VALIDATABLE" confidence="0.9"/>
    <edge id="E-DISCOVERY-ENGINE" type="satisfies" from="REQ-CORE-SPEC-DISCOVERY" to="GOAL-REUSABLE-ENGINE" confidence="0.9"/>
    <edge id="E-FANOUT-ENFORCE" type="satisfies" from="REQ-WORKSPACE-FANOUT" to="GOAL-ENFORCEMENT" confidence="0.85"/>
    <edge id="E-LINT-CEREMONY" type="satisfies" from="REQ-CORE-LINT" to="GOAL-LOW-CEREMONY" confidence="0.8"/>
    <edge id="E-CLI-LINT-CEREMONY" type="satisfies" from="REQ-CLI-LINT" to="GOAL-LOW-CEREMONY" confidence="0.8"/>
    <edge id="E-CORESTRICT-ENFORCE" type="satisfies" from="REQ-CORE-STRICTNESS" to="GOAL-ENFORCEMENT" confidence="0.85"/>

    <!-- Requirements depend on the decisions that motivate them -->
    <edge id="E-XML-DEC" type="dependsOn" from="REQ-XML" to="DEC-XML" confidence="1"/>
    <edge id="E-MIXED-DEC" type="dependsOn" from="REQ-MIXED-CONTENT" to="DEC-MIXED-CONTENT" confidence="1"/>
    <edge id="E-TRACE-DEC" type="dependsOn" from="REQ-TRACE-LOCATORS" to="DEC-TRACE-ENDPOINTS" confidence="1"/>
    <edge id="E-SM-DEC" type="dependsOn" from="REQ-SM" to="DEC-BEHAVIOR-FLAT" confidence="1"/>
    <edge id="E-XML-CON" type="dependsOn" from="REQ-XML" to="CON-XML" confidence="1"/>

    <!-- Requirements mitigate risks / obstacles -->
    <edge id="E-SPECFIRST-DRIFT" type="mitigates" from="REQ-SPEC-FIRST" to="RISK-DRIFT" confidence="0.8"/>
    <edge id="E-HUMAN-VERBOSITY" type="mitigates" from="REQ-HUMAN" to="RISK-VERBOSITY" confidence="0.7"/>
    <edge id="E-NORM-AMBIGUITY" type="mitigates" from="REQ-NORMATIVE-KEYWORDS" to="RISK-AMBIGUITY" confidence="0.8"/>

    <!-- Behavior refines the document entity -->
    <edge id="E-SM-ENTITY" type="refines" from="SM-DOC-LIFECYCLE" to="ENT-DOC" confidence="0.9"/>

    <!-- Requirements verified by tests -->
    <edge id="E-REQUIRED-TEST" type="verifiedBy" from="REQ-REQUIRED-SECTIONS" to="TC-MINIMAL-DOC"/>
    <edge id="E-IDUNIQUE-TEST" type="verifiedBy" from="REQ-ID-UNIQUE" to="TC-UNIQUE-ID"/>
    <edge id="E-INTEGRITY-TEST" type="verifiedBy" from="REQ-TRACE-INTEGRITY" to="TC-TRACE-RESOLVE"/>
    <edge id="E-SMINIT-TEST" type="verifiedBy" from="REQ-SM-INITIAL" to="TC-SM-INITIAL"/>
    <edge id="E-VERSION-TEST" type="verifiedBy" from="REQ-VERSION" to="TC-XSD-VALID"/>

    <!-- Conformance to external standards -->
    <edge id="E-NORM-RFC2119" type="conformsTo" from="REQ-NORMATIVE-KEYWORDS" to="urn:ietf:rfc:2119" toKind="standard" toTitle="RFC 2119"/>
    <edge id="E-RE-IEEE29148" type="conformsTo" from="GOAL-RE-OPERATIONALIZE" to="urn:iso:std:iso-iec-ieee:29148" toKind="standard" toTitle="ISO/IEC/IEEE 29148:2018"/>

    <!-- Lifecycle: 2.1.0 trace model supersedes the 2.0.1 model -->
    <edge id="E-TRACE-SUPERSEDES" type="supersedes" from="REQ-TRACE-EDGE" to="https://rqml.org/schema/rqml-2.0.1.xsd#traceEdge" toKind="schema" toTitle="RQML 2.0.1 traceEdge">
      <notes>2.1.0 replaced flat traceEdge attributes with structured from/to locators.</notes>
    </edge>
    <!-- Toolchain requirements satisfy toolchain goals -->
    <edge id="E-PRIM-ENFORCE" type="satisfies" from="REQ-ENFORCE-PRIMITIVES" to="GOAL-ENFORCEMENT" confidence="0.9"/>
    <edge id="E-API-ENGINE" type="satisfies" from="REQ-CORE-API" to="GOAL-REUSABLE-ENGINE" confidence="0.9"/>
    <edge id="E-OFFLINE-GOAL" type="satisfies" from="REQ-CLI-OFFLINE" to="GOAL-OFFLINE-FAST" confidence="0.85"/>
    <edge id="E-DETERMINISM-QGOAL" type="satisfies" from="REQ-ENFORCE-DETERMINISM" to="QGOAL-DETERMINISTIC" confidence="0.9"/>
    <edge id="E-SPEED-QGOAL" type="satisfies" from="REQ-CLI-SPEED" to="QGOAL-CHECK-SPEED" confidence="0.8"/>

    <!-- Toolchain requirements depend on the decisions that motivate them -->
    <edge id="E-WORKSPACE-DEC" type="dependsOn" from="REQ-WORKSPACE" to="DEC-MONOREPO" confidence="1"/>
    <edge id="E-NOLLM-DEC" type="dependsOn" from="REQ-CORE-NO-LLM" to="DEC-DETERMINISTIC-CHECK" confidence="1"/>
    <edge id="E-DRIFT-DEC" type="dependsOn" from="REQ-CORE-DRIFT" to="DEC-EXPLICIT-TRACE" confidence="1"/>
    <edge id="E-CANON-DEC" type="dependsOn" from="REQ-SCHEMA-CANONICAL" to="DEC-SCHEMA-PACKAGE" confidence="1"/>
    <edge id="E-VERDEC-DEC" type="dependsOn" from="REQ-VERSION-DECOUPLE" to="DEC-VERSION-DECOUPLE" confidence="1"/>
    <edge id="E-MCP-CORE-API" type="dependsOn" from="REQ-MCP-PARITY" to="REQ-CORE-API" confidence="0.9"/>
    <edge id="E-GATE-DRIFT" type="dependsOn" from="REQ-CLI-CHECK-GATE" to="REQ-CORE-DRIFT" confidence="0.9"/>

    <!-- Toolchain requirements mitigate toolchain risks -->
    <edge id="E-NOLLM-RISK" type="mitigates" from="REQ-CORE-NO-LLM" to="RISK-LLM-GATE" confidence="0.9"/>
    <edge id="E-CANON-RISK" type="mitigates" from="REQ-SCHEMA-CANONICAL" to="RISK-SCHEMA-COPY" confidence="0.9"/>
    <edge id="E-COREDEPS-RISK" type="mitigates" from="REQ-CORE-DEPS" to="RISK-CORE-BLOAT" confidence="0.9"/>
    <edge id="E-PRIM-DRIFT" type="mitigates" from="REQ-ENFORCE-PRIMITIVES" to="RISK-DRIFT" confidence="0.8"/>

    <!-- Toolchain requirements verified by toolchain tests -->
    <edge id="E-GATE-TEST" type="verifiedBy" from="REQ-CLI-CHECK-GATE" to="TC-CHECK-GATE"/>
    <edge id="E-DETERMINISM-TEST" type="verifiedBy" from="REQ-ENFORCE-DETERMINISM" to="TC-CHECK-DETERMINISM"/>
    <edge id="E-DRIFT-TEST" type="verifiedBy" from="REQ-CORE-DRIFT" to="TC-DRIFT-DETECT"/>
    <edge id="E-OFFLINE-TEST" type="verifiedBy" from="REQ-CLI-OFFLINE" to="TC-CORE-OFFLINE"/>
    <edge id="E-COREDEPS-TEST" type="verifiedBy" from="REQ-CORE-DEPS" to="TC-CORE-NO-DEPS"/>
    <edge id="E-SCHEMAURL-TEST" type="verifiedBy" from="REQ-SCHEMA-URLS" to="TC-SCHEMA-URL"/>
    <edge id="E-PARITY-TEST" type="verifiedBy" from="REQ-MCP-PARITY" to="TC-MCP-PARITY"/>

    <!-- Behavior refines the implementation-link entity -->
    <edge id="E-SMIMPL-ENTITY" type="refines" from="SM-IMPL-STATUS" to="ENT-IMPL-LINK" confidence="0.9"/>

    <!-- Certified enforcement conforms to a regulated-domain standard -->
    <edge id="E-CERT-IEC62304" type="conformsTo" from="REQ-ENFORCE-CERTIFIED" to="urn:iec:std:62304" toKind="standard" toTitle="IEC 62304"/>

    <!-- ========================================================= -->
    <!-- IMPLEMENTS — code artifacts realizing requirements        -->
    <!-- (ENT-IMPL-LINK: from = external code locator, to = req.   -->
    <!-- URIs are repo-root-relative so rqml check resolves them   -->
    <!-- when run from the repository root.)                       -->
    <!-- ========================================================= -->

    <!-- Format requirements realized by the canonical XSD -->
    <edge id="E-IMPL-DOC-ROOT" type="implements" from="packages/schema/versions/2.2.0/rqml-2.2.0.xsd" fromKind="schema" fromTitle="RQML 2.2.0 XSD" to="REQ-DOC-ROOT"/>
