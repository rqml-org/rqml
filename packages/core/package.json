{
  "name": "@rqml/core",
  "version": "0.2.0",
  "description": "The RQML engine: parse, serialize, validate (XSD + referential integrity), lint, trace, coverage, and drift for .rqml requirements documents. The dependency-clean library every RQML surface reuses.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Gardar Gudgeirsson",
  "keywords": [
    "rqml",
    "requirements",
    "traceability",
    "validation",
    "xsd"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validate": {
      "types": "./dist/validate/index.d.ts",
      "import": "./dist/validate/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "vitest"
  },
  "dependencies": {
    "@rqml/schema": "workspace:^",
    "fast-xml-parser": "^4.5.0",
    "libxml2-wasm": "^0.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
