<?xml version="1.0" encoding="UTF-8"?>
<rqml xmlns="https://rqml.org/schema/2.1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="https://rqml.org/schema/2.1.0 https://rqml.org/schema/rqml-2.1.0.xsd"
      version="2.1.0" docId="RQML-CORE-001" status="draft">

  <meta>
    <title>RQML Core Library</title>
    <system>rqml-core</system>
    <summary>The canonical TypeScript/JavaScript library for RQML. It parses .rqml documents into a typed object model, serializes the model back to XML, validates documents against the bundled RQML schemas, applies strictness-aware semantic lint checks, and answers traceability queries. It is isomorphic (runs identically in browsers and Node), published to npm, and consumed by rqml-vscode, rqml.dev web tooling, and any third-party tool in the TS/JS ecosystem.</summary>
    <authors>
      <author>
        <name>Gardar Gudgeirsson</name>
        <role>Maintainer</role>
      </author>
    </authors>
    <conventions>
      <normativeKeywords>RFC 2119: SHALL/MUST denote mandatory requirements, SHOULD denotes recommendations, MAY denotes optional behaviour.</normativeKeywords>
      <idConventions>Requirements use REQ-&lt;AREA&gt;-NNN; goals GOAL-&lt;AREA&gt;; quality goals QGOAL-&lt;NAME&gt;; packages PKG-&lt;AREA&gt;; test cases TC-&lt;NAME&gt;.</idConventions>
    </conventions>
  </meta>

  <catalogs>
    <actors>
      <actor id="ACT-CONSUMER" name="Library consumer" type="system">
        <description>Application code that imports rqml-core: the rqml-vscode extension, rqml.dev web tooling, or any third-party TS/JS project.</description>
      </actor>
      <actor id="ACT-DEVELOPER" name="Developer" type="human">
        <description>A developer integrating rqml-core into their tooling and calling its public API.</description>
      </actor>
      <actor id="ACT-AGENT" name="Coding agent" type="system">
        <description>An AI coding agent that uses rqml-core (directly or through downstream tools) to author and reason about RQML documents.</description>
      </actor>
    </actors>

    <constraints>
      <constraint id="CON-ISOMORPHIC" severity="blocking">
        <statement>The library must run identically in modern browsers and in Node without code changes by the consumer; the core API must not depend on Node-only built-ins.</statement>
      </constraint>
      <constraint id="CON-WASM-XSD">
        <statement>Schema validation must use a WebAssembly build of libxml2 so a single validation code path works in both browser and Node.</statement>
      </constraint>
      <constraint id="CON-OFFLINE">
        <statement>Parsing, validation, lint, and traceability must function without network access for any document version covered by a bundled schema.</statement>
      </constraint>
      <constraint id="CON-LICENSE">
        <statement>Source code must be licensed under Apache-2.0 to match the upstream RQML standard.</statement>
        <source>rqml standard licensing</source>
      </constraint>
      <constraint id="CON-XSD-COMPAT">
        <statement>Validation must succeed for any document whose declared rqml@version has a bundled schema.</statement>
      </constraint>
      <constraint id="CON-TYPES">
        <statement>The library must be authored in TypeScript and ship type declarations so consumers get full type information.</statement>
      </constraint>
    </constraints>

    <risks>
      <risk id="RISK-WASM-SIZE" severity="medium">
        <statement>The bundled WASM libxml2 build inflates the published package and browser bundle size, discouraging adoption in size-sensitive web tooling.</statement>
        <mitigation>Lazy-load the WASM module so consumers that only parse or lint never pay for it; keep validation in a separately importable entry point.</mitigation>
      </risk>
      <risk id="RISK-SCHEMA-DRIFT" severity="medium">
        <statement>Bundled schemas drift from the canonical schemas served at rqml.org, causing validation results to diverge from the standard.</statement>
        <mitigation>A provenance check fetches upstream schemas and asserts byte-equality against the bundled copies before release.</mitigation>
      </risk>
      <risk id="RISK-VERSION-SKEW" severity="medium">
        <statement>Documents in the wild declare different schema versions (2.0.1 and 2.1.0); validating against the wrong version produces false results.</statement>
        <mitigation>Auto-detect the version from rqml@version and dispatch to the matching bundled schema; bundle all supported versions.</mitigation>
      </risk>
      <risk id="RISK-FALSE-PASS" severity="high">
        <statement>XSD validation passes documents that are structurally valid but semantically broken (missing acceptance criteria, dangling trace targets, ambiguous statements).</statement>
        <mitigation>A semantic linter and traceability resolver complement XSD validation; strictness level controls how aggressive the checks are.</mitigation>
      </risk>
      <risk id="RISK-ROUNDTRIP-LOSS" severity="medium">
        <statement>Parsing then serializing a document loses content (comments, attribute order, whitespace) so the library cannot be used to safely edit documents in place.</statement>
        <mitigation>Define and test a documented round-trip fidelity contract; preserve significant content.</mitigation>
      </risk>
    </risks>

    <decisions>
      <decision id="DEC-TYPESCRIPT" status="approved">
        <context>Implementation language for the canonical library.</context>
        <decision>Author in TypeScript and publish compiled JavaScript with type declarations, so the library is usable from both TS and JS and gives consumers full typing.</decision>
      </decision>
      <decision id="DEC-WASM-LIBXML" status="approved">
        <context>Browsers have no native XSD validator, but validation must match the canonical XSD and run in the browser as well as Node.</context>
        <decision>Bundle a WebAssembly build of libxml2 and use it as the single validation engine across all environments rather than maintaining a separate pure-JS validator.</decision>
        <alternatives>A hand-written pure-JS validator was rejected because it would drift from the authoritative XSD; Node-only xmllint was rejected because it cannot run in the browser.</alternatives>
      </decision>
      <decision id="DEC-BUNDLE-SCHEMAS" status="approved">
        <context>Whether to fetch schemas at runtime or bundle them.</context>
        <decision>Bundle every supported schema version in the package for offline-safe validation.</decision>
      </decision>
      <decision id="DEC-LAZY-WASM" status="approved">
        <context>The WASM engine is large but only needed for validation.</context>
        <decision>Expose validation behind a separate, lazily loaded entry point so parsing, lint, and traceability consumers do not pay the WASM cost.</decision>
      </decision>
    </decisions>

    <policies>
      <policy id="POL-SEMVER" source="semver.org">
        <obligation>The public API follows semantic versioning; breaking API changes require a major version bump.</obligation>
      </policy>
    </policies>
  </catalogs>

  <domain>
    <overview>rqml-core models an RQML document as a typed tree mirroring the RQML schema. Consumers parse XML text into this model, inspect or query it, and serialize it back to XML. Validation, lint, and traceability operate over the same model.</overview>
    <entities>
      <entity id="ENT-DOC" name="RqmlDocument">
        <description>The in-memory representation of a parsed .rqml file: its version, status, docId, meta, and all sections.</description>
        <attr id="ATTR-DOC-VERSION" name="version" type="string" required="true"/>
        <attr id="ATTR-DOC-ID" name="docId" type="string" required="true"/>
        <attr id="ATTR-DOC-STATUS" name="status" type="token" required="true"/>
      </entity>
      <entity id="ENT-REQ" name="Requirement">
        <description>A single requirement node within the model, with id, type, title, priority, status, statement, and acceptance criteria.</description>
        <attr id="ATTR-REQ-ID" name="id" type="string" required="true"/>
        <attr id="ATTR-REQ-TYPE" name="type" type="token" required="true"/>
        <attr id="ATTR-REQ-PRIORITY" name="priority" type="token" required="false"/>
      </entity>
      <entity id="ENT-EDGE" name="TraceEdge">
        <description>A traceability edge connecting two artifacts by id, with a relationship type and optional confidence and metadata.</description>
        <attr id="ATTR-EDGE-FROM" name="from" type="string" required="true"/>
        <attr id="ATTR-EDGE-TO" name="to" type="string" required="true"/>
        <attr id="ATTR-EDGE-TYPE" name="type" type="token" required="true"/>
      </entity>
      <entity id="ENT-DIAG" name="Diagnostic">
        <description>A normalized problem report produced by validation or lint, with location, message, severity, and source.</description>
        <attr id="ATTR-DIAG-LINE" name="line" type="integer" required="false"/>
        <attr id="ATTR-DIAG-COL" name="column" type="integer" required="false"/>
        <attr id="ATTR-DIAG-MSG" name="message" type="string" required="true"/>
        <attr id="ATTR-DIAG-SEV" name="severity" type="token" required="true"/>
        <attr id="ATTR-DIAG-SOURCE" name="source" type="token" required="true"/>
      </entity>
    </entities>
  </domain>

  <goals>
    <goal id="GOAL-CANONICAL" title="Canonical TS/JS implementation" priority="must">
      <statement>Be the single, authoritative TypeScript/JavaScript library for working with RQML documents, so that downstream tools share one implementation rather than re-implementing parsing and validation.</statement>
      <rationale>A shared core prevents the rqml-vscode extension, rqml.dev tooling, and third-party tools from diverging in how they interpret RQML.</rationale>
    </goal>
    <goal id="GOAL-ISOMORPHIC" title="Runs everywhere" priority="must">
      <statement>Work identically in modern browsers and in Node so the same code powers web tooling, the editor extension, and command-line use.</statement>
    </goal>
    <goal id="GOAL-CORRECTNESS" title="Authoritative validation" priority="must">
      <statement>Produce validation results that match the canonical RQML XSD for the document's declared version.</statement>
    </goal>
    <goal id="GOAL-DX" title="Excellent developer experience" priority="must">
      <statement>Give consumers a small, well-typed, documented public API that is easy to adopt from both TypeScript and JavaScript.</statement>
      <rationale>Adoption by third-party developers depends on a clean, stable, fully typed surface.</rationale>
    </goal>
    <goal id="GOAL-SEMANTIC" title="Catch semantic defects" priority="should">
      <statement>Detect requirement-quality and traceability defects that structural XSD validation alone cannot catch.</statement>
    </goal>

    <qgoal id="QGOAL-TYPE-SAFETY" title="Full type coverage" priority="must">
      <statement>The public API is fully typed with no implicit any in shipped declarations.</statement>
      <metric>Type declarations ship for 100% of the public API; the package compiles cleanly under TypeScript strict mode.</metric>
    </qgoal>
    <qgoal id="QGOAL-BUNDLE-SIZE" title="Small parse/lint footprint" priority="should">
      <statement>Consumers that only parse and lint can do so without loading the validation WASM engine.</statement>
      <metric>Importing the parsing and lint entry points pulls in no WASM and adds no more than 50&#160;KB minified+gzipped.</metric>
    </qgoal>
    <qgoal id="QGOAL-PARSE-PERF" title="Fast parsing" priority="should">
      <statement>Parsing is fast enough to run on every keystroke-debounced edit in an editor.</statement>
      <metric>Parsing a 2000-line document into the model completes in under 50&#160;ms on a typical developer laptop.</metric>
    </qgoal>
  </goals>

  <scenarios>
    <scenario id="SCN-EDITOR" title="Validate in the editor" actorRef="ACT-CONSUMER">
      <narrative>The rqml-vscode extension imports rqml-core, parses the open .rqml document on change, validates it, and renders the returned diagnostics as editor squiggles with line and column positions.</narrative>
    </scenario>
    <scenario id="SCN-WEB" title="Validate in the browser" actorRef="ACT-CONSUMER">
      <narrative>A rqml.dev web playground loads rqml-core in the browser, validates a pasted document using the WASM libxml2 engine, and shows results without any server round-trip.</narrative>
    </scenario>
    <scenario id="SCN-THIRD-PARTY" title="Third-party integration" actorRef="ACT-DEVELOPER">
      <narrative>A developer installs rqml-core from npm, imports the typed API, parses a document, queries which requirements satisfy a goal, and renders a coverage report in their own tool.</narrative>
    </scenario>
    <scenario id="SCN-ROUNDTRIP" title="Programmatic edit" actorRef="ACT-AGENT">
      <narrative>An agent parses a document into the model, adds a new requirement node, and serializes back to XML; the unchanged parts of the document are preserved so the diff is minimal.</narrative>
    </scenario>
    <scenario id="SCN-OLD-SCHEMA" title="Older schema version" actorRef="ACT-CONSUMER">
      <narrative>A consumer validates a document declaring version 2.0.1 while the library bundles both 2.0.1 and 2.1.0; the library detects the declared version and validates against the matching bundled schema.</narrative>
    </scenario>
    <misuseCase id="SCN-DRIFT" title="Bundled schema drifts from upstream">
      <narrative>An upstream schema is patched at rqml.org but the bundled copy is not updated, so validation diverges from the canonical standard and consumers get misleading results.</narrative>
    </misuseCase>
    <edgeCase id="SCN-MALFORMED" title="Malformed XML input">
      <narrative>A consumer passes XML that is not well-formed. Parsing fails with a structured error carrying line and column rather than throwing an opaque exception.</narrative>
    </edgeCase>
  </scenarios>

  <requirements>
    <reqPackage id="PKG-MODEL" title="Parsing and object model">
      <description>Parse .rqml documents into a typed model and serialize the model back to XML.</description>
      <req id="REQ-PARSE" type="FR" title="Parse to typed model" priority="must" status="draft">
        <statement>The library SHALL parse a well-formed .rqml document string into a typed in-memory model that mirrors the RQML schema structure.</statement>
        <acceptance>
          <criterion id="CRIT-PARSE-1">
            <given>A well-formed RQML document string</given>
            <when>The parse function is called on it</when>
            <then>It returns a typed model whose docId, version, status, meta, and requirements match the source.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-PARSE-ERRORS" type="FR" title="Structured parse errors" priority="must" status="draft">
        <statement>When input is not well-formed XML, the parser SHALL return a structured error carrying line, column, and a human-readable message rather than throwing an opaque exception.</statement>
        <acceptance>
          <criterion id="CRIT-PARSE-ERR-1">
            <given>A string that is not well-formed XML</given>
            <when>The parse function is called on it</when>
            <then>A structured parse error is produced with line, column, and message; no unhandled exception escapes.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-SERIALIZE" type="FR" title="Serialize model to XML" priority="must" status="draft">
        <statement>The library SHALL serialize a model back to a well-formed .rqml XML string that re-parses to an equivalent model.</statement>
        <acceptance>
          <criterion id="CRIT-SERIALIZE-1">
            <given>A model produced by parsing a valid document</given>
            <when>It is serialized and then re-parsed</when>
            <then>The re-parsed model is structurally equivalent to the original.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-ROUNDTRIP" type="NFR" title="Round-trip fidelity" priority="should" status="draft">
        <statement>Parsing then serializing an unmodified document SHOULD preserve element and attribute content so that editing a single node yields a minimal diff against the source.</statement>
      </req>
      <req id="REQ-MODEL-TYPES" type="DR" title="Exported model types" priority="must" status="draft">
        <statement>The library SHALL export TypeScript types for every model node (document, sections, requirement, trace edge, diagnostic) so consumers can hold and manipulate the model in a type-safe way.</statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-VALIDATE" title="Schema validation">
      <description>Validate documents against the bundled RQML schemas using a single WASM engine.</description>
      <req id="REQ-XSD-VALIDATE" type="FR" title="XSD validation" priority="must" status="draft">
        <statement>The library SHALL validate a document against the RQML XSD for its declared version and return a list of normalized diagnostics, each with location, message, and severity.</statement>
        <acceptance>
          <criterion id="CRIT-XSD-1">
            <given>A document that conforms to its declared schema version</given>
            <when>Validation is run</when>
            <then>The result reports valid with an empty diagnostics list.</then>
          </criterion>
          <criterion id="CRIT-XSD-2">
            <given>A document that violates its declared schema</given>
            <when>Validation is run</when>
            <then>The result reports invalid and each violation appears as a diagnostic with line, optional column, and a human-readable message.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-WASM-LIBXML" type="CR" title="WASM libxml2 engine" priority="must" status="draft">
        <statement>Validation SHALL use a WebAssembly build of libxml2 as its single engine so that results are identical in browsers and in Node.</statement>
        <acceptance>
          <criterion id="CRIT-WASM-1">
            <given>The same document validated in a browser environment and in Node</given>
            <when>Validation is run in each</when>
            <then>Both environments produce the same valid/invalid verdict and equivalent diagnostics.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-VERSION-DISPATCH" type="FR" title="Schema version dispatch" priority="must" status="draft">
        <statement>The library SHALL read rqml@version from the document and validate against the matching bundled schema; an explicit override SHALL be accepted to force a specific schema version.</statement>
        <acceptance>
          <criterion id="CRIT-VERSION-1">
            <given>A document declaring version 2.0.1 with both 2.0.1 and 2.1.0 schemas bundled</given>
            <when>Validation runs without an override</when>
            <then>The 2.0.1 schema is used.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-BUNDLE-SCHEMAS" type="FR" title="Bundled schema versions" priority="must" status="draft">
        <statement>The library SHALL bundle every supported RQML schema version so that validation works offline without fetching schemas at runtime.</statement>
      </req>
      <req id="REQ-LAZY-WASM" type="NFR" title="Lazy validation engine" priority="should" status="draft">
        <statement>The validation engine SHALL be loaded lazily and exposed through a separate entry point so that consumers using only parsing, lint, or traceability do not load the WASM module.</statement>
      </req>
      <req id="REQ-OFFLINE" type="OR" title="Offline operation" priority="must" status="draft">
        <statement>Parsing, validation, lint, and traceability SHALL operate without network access for any document whose declared version is covered by a bundled schema.</statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-LINT" title="Semantic lint">
      <description>Strictness-aware semantic checks beyond structural validation.</description>
      <req id="REQ-LINT" type="FR" title="Semantic lint" priority="should" status="draft">
        <statement>The library SHALL provide a semantic lint pass that reports requirement-quality and traceability defects as diagnostics distinct from XSD validation errors.</statement>
        <acceptance>
          <criterion id="CRIT-LINT-1">
            <given>A structurally valid document with a requirement that has no acceptance criteria, at standard strictness</given>
            <when>Lint is run</when>
            <then>A diagnostic flags the missing acceptance criteria.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-STRICTNESS" type="FR" title="Strictness levels" priority="should" status="draft">
        <statement>Lint SHALL support graduated strictness levels (relaxed, standard, strict, certified) where each higher level enables additional checks, and the level SHALL be selectable by the caller.</statement>
      </req>
      <req id="REQ-LINT-RULES" type="FR" title="Documented rule set" priority="should" status="draft">
        <statement>Each lint rule SHALL carry a stable identifier and description so consumers can reference, suppress, or document individual rules.</statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-TRACE" title="Traceability queries">
      <description>Resolve and analyze traceability relationships across the model.</description>
      <req id="REQ-TRACE-RESOLVE" type="FR" title="Resolve trace edges" priority="must" status="draft">
        <statement>The library SHALL resolve trace edge local locators to the artifacts they reference and report any edge whose endpoints do not resolve to a declared id.</statement>
        <acceptance>
          <criterion id="CRIT-TRACE-1">
            <given>A document containing a trace edge whose target id does not exist</given>
            <when>Trace resolution runs</when>
            <then>A diagnostic identifies the edge and its unresolved endpoint.</then>
          </criterion>
        </acceptance>
      </req>
      <req id="REQ-COVERAGE" type="FR" title="Coverage matrix" priority="should" status="draft">
        <statement>The library SHALL produce a coverage view mapping each requirement to its outgoing and incoming trace edges grouped by edge type (satisfies, dependsOn, mitigates, verifiedBy).</statement>
      </req>
      <req id="REQ-ORPHAN" type="FR" title="Orphan detection" priority="should" status="draft">
        <statement>The library SHALL identify requirements that have no satisfies edge to any goal or scenario and requirements that have no verifiedBy edge to any verification artifact.</statement>
      </req>
      <req id="REQ-IMPACT" type="FR" title="Impact analysis" priority="may" status="draft">
        <statement>The library MAY answer impact queries that, given an artifact id, return the set of artifacts transitively connected to it through trace edges.</statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-DIST" title="Distribution and platform">
      <description>How the library is built, typed, and published.</description>
      <req id="REQ-ISOMORPHIC" type="CR" title="Isomorphic runtime" priority="must" status="draft">
        <statement>The core API SHALL run in modern browsers and in Node without consumer code changes and SHALL NOT depend on Node-only built-ins in any code path reachable from the browser entry points.</statement>
      </req>
      <req id="REQ-TYPED-API" type="NFR" title="Typed public API" priority="must" status="draft">
        <statement>The library SHALL be written in TypeScript and ship type declarations for its entire public API, compiling cleanly under TypeScript strict mode.</statement>
      </req>
      <req id="REQ-ESM" type="CR" title="Module format" priority="must" status="draft">
        <statement>The library SHALL be published as an ES module with named exports and SHALL provide tree-shakeable entry points so unused features are excluded from consumer bundles.</statement>
      </req>
      <req id="REQ-NPM" type="IR" title="npm distribution" priority="must" status="draft">
        <statement>The library SHALL be published to npm as a public package consumable by third-party TS/JS projects.</statement>
      </req>
      <req id="REQ-API-STABILITY" type="NFR" title="Semantic versioning" priority="must" status="draft">
        <statement>The public API SHALL follow semantic versioning so that breaking changes are signalled by a major version bump.</statement>
      </req>
    </reqPackage>

    <reqPackage id="PKG-PROVENANCE" title="Schema provenance and licensing">
      <description>Keep bundled schemas faithful to upstream and align licensing with the standard.</description>
      <req id="REQ-PROVENANCE" type="OR" title="Schema provenance check" priority="should" status="draft">
        <statement>The build SHALL verify that each bundled schema is byte-equal to the corresponding canonical schema published at rqml.org and SHALL fail the release if they differ.</statement>
      </req>
      <req id="REQ-LICENSE" type="OR" title="Apache-2.0 license" priority="must" status="draft">
        <statement>The library SHALL be licensed under Apache-2.0 to match the upstream RQML standard.</statement>
      </req>
    </reqPackage>
  </requirements>

  <verification>
    <testSuite id="TS-CORE" title="Core library tests">
      <description>Unit and integration tests covering parsing, serialization, validation across environments, lint, and traceability, plus build-time provenance checks.</description>
    </testSuite>
    <testCase id="TC-PARSE" type="unit" title="Parse valid document">
      <steps>Parse a known-good fixture and inspect the returned model.</steps>
      <expected>The model's docId, version, status, and requirement ids match the fixture.</expected>
    </testCase>
    <testCase id="TC-PARSE-ERR" type="unit" title="Parse malformed input">
      <steps>Parse a string that is not well-formed XML.</steps>
      <expected>A structured parse error with line, column, and message is returned; no exception escapes.</expected>
    </testCase>
    <testCase id="TC-ROUNDTRIP" type="unit" title="Serialize round-trip">
      <steps>Parse a fixture, serialize it, and re-parse the output.</steps>
      <expected>The re-parsed model is structurally equivalent to the original.</expected>
    </testCase>
    <testCase id="TC-VALID" type="integration" title="Valid document validates clean">
      <steps>Validate a conforming fixture against its declared schema version.</steps>
      <expected>Result is valid with an empty diagnostics list.</expected>
    </testCase>
    <testCase id="TC-INVALID" type="integration" title="Invalid document reports diagnostics">
      <steps>Validate a fixture that violates the schema.</steps>
      <expected>Result is invalid; each violation is a diagnostic with line and message.</expected>
    </testCase>
    <testCase id="TC-WASM-PARITY" type="integration" title="Browser and Node parity">
      <steps>Validate the same fixture under a browser-like environment and under Node.</steps>
      <expected>Both produce the same verdict and equivalent diagnostics.</expected>
    </testCase>
    <testCase id="TC-VERSION" type="integration" title="Version dispatch">
      <steps>Validate a 2.0.1 fixture with both schemas bundled and no override.</steps>
      <expected>The 2.0.1 schema is selected.</expected>
    </testCase>
    <testCase id="TC-LAZY" type="unit" title="Parse path excludes WASM">
      <steps>Import only the parsing/lint entry point and inspect what modules load.</steps>
      <expected>The WASM validation module is not loaded.</expected>
    </testCase>
    <testCase id="TC-LINT-AC" type="unit" title="Lint flags missing acceptance criteria">
      <steps>Lint a structurally valid document with a requirement lacking acceptance criteria at standard strictness.</steps>
      <expected>A diagnostic flags the missing acceptance criteria.</expected>
    </testCase>
    <testCase id="TC-TRACE-UNRESOLVED" type="unit" title="Unresolved trace target">
      <steps>Resolve traces on a document with an edge pointing at a non-existent id.</steps>
      <expected>A diagnostic identifies the edge and unresolved endpoint.</expected>
    </testCase>
    <testCase id="TC-COVERAGE" type="unit" title="Coverage matrix">
      <steps>Build the coverage view for a fixture with mixed trace edge types.</steps>
      <expected>Each requirement maps to its edges grouped by type.</expected>
    </testCase>
    <testCase id="TC-TYPES" type="inspection" title="Type declarations complete">
      <steps>Compile the public API under TypeScript strict mode and check emitted declarations.</steps>
      <expected>Declarations exist for the whole public API with no implicit any.</expected>
    </testCase>
    <testCase id="TC-PROVENANCE" type="integration" title="Bundled schema matches upstream">
      <steps>Fetch each schema from rqml.org and diff byte-for-byte against the bundled copy.</steps>
      <expected>Diffs are empty for every supported version.</expected>
    </testCase>
    <testCase id="TC-PARSE-PERF" type="performance" title="Parsing latency">
      <steps>Parse a 2000-line fixture and measure wall-clock time.</steps>
      <expected>Parsing completes in under 50 ms on a typical developer laptop.</expected>
    </testCase>
  </verification>

  <trace>
    <!-- Requirements satisfying goals -->
